              </:row>

              <:row>
                <.table_td>link</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines path of link
                </.table_td>
              </:row>

              <:row>
                <.table_td>link_title</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines link name
                </.table_td>
              </:row>

              <:row>
                <.table_td>active</.table_td>

                <.table_td>boolean</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Indicates whether the element is currently active and visible
                </.table_td>
              </:row>

              <:row>
                <.table_td>rest</.table_td>

                <.table_td>global</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Global attributes that define defaults merged with attributes provided by the caller.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/table-content/#overview"}
            title="Overview of Table of Contents"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-variants-colors"}
            title="Table content Variants and Colors"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-rounded"}
            title="Rounded prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-border"}
            title="Border prop"
          />
          <:content link={~p"/chelekom/docs/table-content/#table-content-size"} title="Size prop" />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-space"}
            title="Space prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-padding"}
            title="Padding prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-title"}
            title="Title prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-animated"}
            title="Animated prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-content-item"}
            title="Content item component"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-content-item-title"}
            title="Content item title prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-content-item-icons"}
            title="Content item icon and icon class props"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-content-item-active"}
            title="Content item active prop"
          />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-content-item-font-weight"}
            title="Content item fon weight prop"
          />
          <:content link={~p"/chelekom/docs/table-content/#item-slot"} title="Item slot" />
          <:content
            link={~p"/chelekom/docs/table-content/#table-content-nested"}
            title="Nested content"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
