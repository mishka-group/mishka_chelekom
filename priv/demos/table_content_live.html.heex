                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag" title="List of props">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-content-item-icons">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-content-item-icons"}>
              Content item icon and icon class props
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>icon</.custom_inline_code>
            prop displays an icon alongside the content, supporting Heroicons. You can customize the icon's appearance using the
            <.custom_inline_code>icon_class</.custom_inline_code>
            prop to apply specific CSS classes for size, color, and styling.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_11}>
            <.table_content id="table-content-example-11" variant="bordered" padding="extra_small">
              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item icon="hero-tag" icon_class="!size-8 text-rose-300">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-content-item-active">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-content-item-active"}>
              Content item active prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>active</.custom_inline_code>
            attribute is a boolean used to indicate whether the current item is selected or active. When set to <.custom_inline_code>true</.custom_inline_code>, it applies specific styles (like bold text) to visually highlight the item as active or currently selected. By default, it's set to <.custom_inline_code>false</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_12}>
            <.table_content
              id="table-content-example-12"
              color="dawn"
              variant="bordered"
              padding="extra_small"
            >
              <.content_item active>
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-content-item-font-weight">
            <.link patch={
              ~p"/chelekom/docs/table-content/#table-content-content-item-font-weight"
            }>
              Content item font weight prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>font_weight</.custom_inline_code>
            attribute allows you to apply custom font weight to a content item by using any Tailwind CSS font weight classes. You can set values like <.custom_inline_code>font-light</.custom_inline_code>, <.custom_inline_code>font-normal</.custom_inline_code>, or
            <.custom_inline_code>font-bold</.custom_inline_code>
            to control the thickness of the text, giving you flexibility in how the content is displayed.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_13}>
            <.table_content
              id="table-content-example-13"
              color="primary"
              variant="bordered"
              padding="extra_small"
            >
              <.content_item font_weight="font-bold" active>
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item font_weight="font-thin">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item font_weight="font-semibold">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item font_weight="font-light">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item font_weight="font-black">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item font_weight="font-bold">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="item-slot">
            <.link patch={~p"/chelekom/docs/table-content/#item-slot"}>
              Item slot
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>item</.custom_inline_code>
            slot is designed for adding custom content and links within a component. It simplifies the process of integrating dynamic content into the component without needing to rely on the more complex
            <.custom_inline_code>content_item</.custom_inline_code>
            slot. By using the
            <.custom_inline_code>item</.custom_inline_code>
            slot, you can easily define and display items such as titles, icons, or links, making the component more flexible and user-friendly. This approach is especially useful when you want to customize individual elements with attributes like class, title, or active state, giving you more control over the presentation and behavior of your content.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_15}>
