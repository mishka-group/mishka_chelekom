              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-content-item-title">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-content-item-title"}>
              Content item title prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>title</.custom_inline_code>
            prop in the
            <.custom_inline_code>content_item</.custom_inline_code>
            component allows you to add a title to a group of items when using
            <.custom_inline_code>content_wrapper</.custom_inline_code>
            inside <.custom_inline_code>content_item</.custom_inline_code>. By setting the <.custom_inline_code>title</.custom_inline_code>, you can label each group, making it easier to organize and structure multiple content items under a specific heading. This helps improve readability and user navigation, especially when dealing with nested or grouped content.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_10}>
            <.table_content
              id="table-content-example-10"
              color="dark"
              variant="bordered"
              padding="extra_small"
            >
              <.content_item icon="hero-hashtag" title="List of props">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-hashtag" title="List of props">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag" title="List of props">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-hashtag" title="List of props">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
