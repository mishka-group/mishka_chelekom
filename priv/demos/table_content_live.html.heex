                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-title">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-title"}>
              Title prop
            </.link>
          </.heading2>

          <.cp>
            You can add a title to your
            <.link navigate={~p"/chelekom/docs/table-content"}>Table of Contents component</.link>
            by using the
            <.custom_inline_code>title</.custom_inline_code>
            attribute in the
            <.custom_inline_code>table_content</.custom_inline_code>
            component. This adds a clear heading, helping users understand the content. If omitted, the content is displayed without a header, giving you flexibility in design.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_7}>
            <.table_content
              id="table-content-example-7"
              color="danger"
              variant="bordered"
              padding="extra_small"
              title="Sample table of contents"
            >
              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-hashtag" active>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-animated">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-animated"}>
              Animated prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>animated</.custom_inline_code>
            attribute is a boolean and defaults to <.custom_inline_code>false</.custom_inline_code>. When set to <.custom_inline_code>true</.custom_inline_code>, it adds the Tailwind
            <.custom_inline_code>scroll-smooth</.custom_inline_code>
            class to the HTML tag, enabling smooth scrolling, even if the class isn’t added manually to your application.
          </.cp>

          <.custom_block position="left" color="danger" class="my-8" border="medium">
            <.cp>
              Notice: If you've already added smooth scrolling via CSS files or directly to the HTML tag of your project, you don't need to use the
              <.custom_inline_code>animated</.custom_inline_code>
              prop.
            </.cp>
          </.custom_block>

          <.custom_code_wrapper code_class="text-xs" code={@code_8}>
            <.table_content
              id="table-content-example-8"
              color="silver"
              variant="bordered"
              padding="extra_small"
            >
              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
