              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-padding">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
              Padding prop
            </.link>
          </.heading2>

          <.cp>
            The padding prop offers values such as <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_6}>
            <.table_content
              id="table-content-example-6"
              color="info"
              variant="bordered"
              padding="quadruple_large"
            >
              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

