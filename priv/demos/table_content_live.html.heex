            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-content-item">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-content-item"}>
              Content item component
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>content_item</.custom_inline_code>
            component represents a single content item with optional custom styling. It supports
            <.custom_inline_code>@active</.custom_inline_code>
            for bolding, <.custom_inline_code>@font_weight</.custom_inline_code>, and additional
            <.custom_inline_code>@class</.custom_inline_code>
            for custom styles. If an icon is provided via <.custom_inline_code>@icon</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_9}>
            <.table_content
              id="table-content-example-9"
              color="warning"
              variant="bordered"
              padding="extra_small"
            >
