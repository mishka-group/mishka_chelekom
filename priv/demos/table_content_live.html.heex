                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-size">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>
              Size prop
            </.link>
          </.heading2>

          <.cp>
            The size prop offers values such as <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_4}>
            <.table_content
              id="table-content-example-4"
              color="info"
              variant="bordered"
              size="extra_large"
            >
              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
