<Layouts.app flash={@flash}>
  <div class="lg:grid lg:grid-cols-12 mt-5 max-w-5xl mx-auto">
    <.custom_nav active="chelekom-docs-table-content" />
    <div class="lg:col-span-10">
      <.custom_info
        title="Table of Content"
        description="Phoenix LiveView table content component with links for smooth scrolling to specific items using anchor tags."
        mix="mix mishka.ui.gen.component table_content"
        github="https://github.com/mishka-group/mishka_chelekom/blob/master/priv/components/table_content.eex"
        tags={["Component", "Stateless", "JS-module"]}
      />
      <.custom_tab id="chelekom-table-content-tab">
        <:documentation_panel>
          <.heading2 class="mb-5" id="overview">
            <.link patch={~p"/chelekom/docs/table-content/#overview"}>
              Overview of Table of Contents Phoenix LiveView component
            </.link>
          </.heading2>

          <.cp>
            The <strong>Mishka Chelekom Table of Contents</strong>
            component is a flexible and customizable <strong>Phoenix LiveView</strong>
            solution for organizing and displaying a navigable list of sections within a page.
          </.cp>

          <.custom_code_wrapper elements_class="grid md:grid-cols-2 gap-5">
            <.table_content padding="extra_small" rounded="medium">
              <.content_item title="Table content main props">
                <.content_wrapper>
                  <.content_item icon="hero-chevron-right">
                    <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>
                      Space
                    </.link>
                  </.content_item>

                  <.content_item icon="hero-chevron-right">
                    <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                      Padding
                    </.link>
                  </.content_item>

                  <.content_item icon="hero-chevron-right">
                    <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                      Rounded
                    </.link>
                  </.content_item>

                  <.content_item icon="hero-chevron-right">
                    <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>
                      Size
                    </.link>
                  </.content_item>
                </.content_wrapper>
              </.content_item>

              <.content_item title="Table content item props">
                <.content_wrapper>
                  <.content_item icon="hero-chevron-right">
                    <.link patch={~p"/chelekom/docs/table-content/#table-content-content-item"}>
                      Content item component
                    </.link>
                  </.content_item>

                  <.content_item icon="hero-chevron-right">
                    <.link patch={
                      ~p"/chelekom/docs/table-content/#table-content-content-item-title"
                    }>
                      Content item title prop
                    </.link>
                  </.content_item>

                  <.content_item icon="hero-chevron-right">
                    <.link patch={
                      ~p"/chelekom/docs/table-content/#table-content-content-item-active"
                    }>
                      Content item active prop
                    </.link>
                  </.content_item>
                </.content_wrapper>
              </.content_item>
            </.table_content>

            <.table_content space="medium" padding="extra_small">
              <.content_item icon="hero-link" icon_class="!size-[18px]" active>
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-link" icon_class="!size-[18px]">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-link" icon_class="!size-[18px]">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-link" icon_class="!size-[18px]">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item icon="hero-link" icon_class="!size-[18px]">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item icon="hero-link" icon_class="!size-[18px]">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.cp margin="mt-5">
            This
            <strong>
              <.link
                title="Phoenix LiveView component"
                class="transition-colors hover:text-[#448D96]"
                navigate={~p"/chelekom"}
              >
                Phoenix LiveView component
              </.link>
            </strong>
            supports responsive design, customizable styles, and smooth scrolling to ensure a seamless navigation experience. Perfect for enhancing the readability and usability of your content-heavy pages.
          </.cp>

          <.custom_block position="left" color="success" class="my-8" border="medium">
            <.cp>
              By using the class prop, you can apply custom classes or Tailwind CSS classes to customize the appearance and behavior of the components, allowing for flexible design changes.
            </.cp>
          </.custom_block>

          <.heading2 margin="my-5" id="table-content-variants-colors">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
              Table contetn Variants and Colors
            </.link>
          </.heading2>

          <.cp>
            The table content component
            supports multiple style variants, including <.custom_inline_code>default</.custom_inline_code>, <.custom_inline_code>base</.custom_inline_code>, <.custom_inline_code>gradient</.custom_inline_code>, <.custom_inline_code>outline</.custom_inline_code>, and <.custom_inline_code>bordered</.custom_inline_code>.
            It also offers a variety of colors such as <.custom_inline_code>natural</.custom_inline_code>, <.custom_inline_code>base</.custom_inline_code>, <.custom_inline_code>white</.custom_inline_code>, <.custom_inline_code>primary</.custom_inline_code>, <.custom_inline_code>secondary</.custom_inline_code>, <.custom_inline_code>primary</.custom_inline_code>, <.custom_inline_code>success</.custom_inline_code>, <.custom_inline_code>warning</.custom_inline_code>, <.custom_inline_code>danger</.custom_inline_code>, <.custom_inline_code>info</.custom_inline_code>, <.custom_inline_code>silver</.custom_inline_code>, <.custom_inline_code>dark</.custom_inline_code>, <.custom_inline_code>misc</.custom_inline_code>, <.custom_inline_code>dawn</.custom_inline_code>,
            and <.custom_inline_code>silver</.custom_inline_code>, providing extensive flexibility to match any design need.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_1}>
            <.table_content id="table-content-example-1">
              <:item
                icon="hero-chevron-right"
                link_title="Content item component"
                link={~p"/chelekom/docs/table-content/#table-content-content-item"}
              >
              </:item>

              <.content_item
                icon="hero-hashtag"
                link_title="Overview"
                link={~p"/chelekom/docs/table-content/#overview"}
              />

              <.content_item icon="hero-hashtag" active>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-rounded">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
              Rounded prop in Phoenix LiveView table content Component
            </.link>
          </.heading2>

          <.cp>
            The rounded prop offers values like <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_2}>
            <.table_content
              id="table-content-example-2"
              color="info"
              variant="bordered"
              rounded="extra_large"
            >
              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#overview"}>Overview</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-variants-colors"}>
                  Color and Variants
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-space"}>Space</.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-padding"}>
                  Padding
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag" active>
                <.link patch={~p"/chelekom/docs/table-content/#table-content-rounded"}>
                  Rounded
                </.link>
              </.content_item>

              <.content_item icon="hero-hashtag">
                <.link patch={~p"/chelekom/docs/table-content/#table-content-size"}>Size</.link>
              </.content_item>
            </.table_content>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="table-content-border">
            <.link patch={~p"/chelekom/docs/table-content/#table-content-border"}>
              Border prop
            </.link>
          </.heading2>

          <.cp>
            The border prop offers values like <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_3}>
            <.table_content
              id="table-content-example-3"
