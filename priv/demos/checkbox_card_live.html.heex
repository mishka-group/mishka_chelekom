          <:content
            link={~p"/chelekom/docs/forms/checkbox-card/#checkbox-card-cols-gap"}
            title="Cols gap prop"
          />
          <:content
            link={~p"/chelekom/docs/forms/checkbox-card/#checkbox-card-show-checkbox"}
            title="Show checkbox prop"
          />
          <:content
            link={~p"/chelekom/docs/forms/checkbox-card/#checkbox-card-reverse"}
            title="Reverse prop"
          />
          <:content
