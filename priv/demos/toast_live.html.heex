                phx-value-pos="toast-example-22"
              >
                Show Secondary
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-12"}
              id="toast_white_doc_12"
              variant="outline"
              color="natural"
            >
              Toast outline variant White 12
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-13"}
              id="toast_dark_doc_13"
