                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-20"
              >
                Show Dawn
              </.button>
              <.button
                variant="outline"
                color="primary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-21"
              >
                Show Primary
              </.button>
              <.button
