                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-95"
              >
                Show Center (Success, Bottom)
              </.button>
              <.button
                variant="outline"
                color="silver"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-96"
              >
                Show Right (silver, Bottom)
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-91"}
              id="toast_horizontal_doc_91"
              horizontal="left"
              vertical="top"
              color="info"
              variant="default"
            >
              Horizontal Left (Info, Top) 91
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-92"}
              id="toast_horizontal_doc_92"
              horizontal="center"
              vertical="top"
              color="silver"
              variant="default"
            >
              Horizontal Center (silver, Top) 92
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-93"}
              id="toast_horizontal_doc_93"
              horizontal="right"
              vertical="top"
              color="primary"
              variant="default"
            >
              Horizontal Right (Primary, Top) 93
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-94"}
              id="toast_horizontal_doc_94"
              horizontal="left"
              vertical="bottom"
              color="danger"
              variant="default"
            >
              Horizontal Left (Danger, Bottom) 94
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-95"}
              id="toast_horizontal_doc_95"
              horizontal="center"
              vertical="bottom"
              color="success"
              variant="default"
            >
              Horizontal Center (Success, Bottom) 95
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-96"}
              id="toast_horizontal_doc_96"
              horizontal="right"
              vertical="bottom"
              color="silver"
              variant="default"
            >
              Horizontal Right (silver, Bottom) 96
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-horizontal-space">
            <.link patch={~p"/chelekom/docs/toast/#toast-horizontal-space"}>
              Horizontal space prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>horizontal_space</.custom_inline_code>
            attribute in the Phoenix LiveView toast component defines the spacing between items in the horizontal direction. This prop offers several predefined values such as <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. These values determine the size of the space between items, with increasing amounts of space from extra_small to extra_large. The default value is set to <.custom_inline_code>extra_small</.custom_inline_code>, but you can customize it as needed to control how close or far apart elements are displayed horizontally. The corresponding utility classes are applied to adjust the spacing for both left and right-aligned items, ensuring a flexible and customizable layout.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_14}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="info"
                variant="outline"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-97"
              >
                Show Extra Small Horizontal Space
              </.button>
              <.button
                variant="outline"
                color="silver"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-98"
              >
                Show Small Horizontal Space
              </.button>
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-99"
              >
                Show Medium Horizontal Space (danger)
              </.button>
              <.button
                variant="outline"
                color="dawn"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-100"
              >
                Show Large Horizontal Space (dawn)
