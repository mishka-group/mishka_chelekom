              >
                Show No Content Border
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-102"}
              id="toast_content_border_doc_102"
              content_border="extra_small"
              variant="default"
              color="info"
            >
              Content Border extra small
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-103"}
              id="toast_content_border_doc_103"
              content_border="small"
              variant="default"
              color="silver"
            >
              Content Border small
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-104"}
              id="toast_content_border_doc_104"
              content_border="medium"
              variant="default"
              color="primary"
            >
              Content Border medium
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-105"}
              id="toast_content_border_doc_105"
              content_border="large"
              variant="default"
              color="danger"
            >
              Content Border large
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-106"}
              id="toast_content_border_doc_106"
              content_border="extra_large"
              variant="default"
              color="success"
            >
              Content Border extra large
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-107"}
              id="toast_content_border_doc_107"
              content_border="none"
              variant="default"
              color="silver"
            >
              No Content Border
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-border-position">
            <.link patch={~p"/chelekom/docs/toast/#toast-border-position"}>
              Border position prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>border_position</.custom_inline_code>
            attribute in the Phoenix LiveView toast component allows you to specify where the border should be applied within the element. By default, it is set to <.custom_inline_code>start</.custom_inline_code>, which means the border will be positioned on the start side of the element (typically the left side in left-to-right layouts).

            There are options like
            <.custom_inline_code>start</.custom_inline_code>
            and <.custom_inline_code>end</.custom_inline_code>, each determining whether the border is applied at the beginning or the end of the element. These values give developers control over the border’s placement, allowing for more flexible design adjustments. You can also pass a custom binary value to apply the border in unique ways, and if no value is provided, it defaults to <.custom_inline_code>start</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_16}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="warning"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-108"
              >
                Show Start Border
              </.button>
              <.button
                variant="outline"
                color="misc"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-109"
              >
                Show End Border
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-108"}
              id="toast_border_doc_108"
              border_position="start"
              content_border="medium"
              color="info"
              variant="outline"
            >
              Border at start position
            </.toast>

            <.toast
              :if={@toast_pos == "toast-example-109"}
              id="toast_border_doc_109"
              border_position="end"
              content_border="medium"
              color="primary"
              variant="default"
            >
              Border at end position (Primary) 109
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-row-reverse">
            <.link patch={~p"/chelekom/docs/toast/#toast-row-reverse"}>
              Row reverse prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>row_direction</.custom_inline_code>
            prop in the Phoenix LiveView toast component allows you to control the order in which the content and dismiss button are displayed. By default, the content appears first, followed by the dismiss button, with the
            <.custom_inline_code>row_direction</.custom_inline_code>
            set to <.custom_inline_code>none</.custom_inline_code>, applying a standard left-to-right layout. However, when the
            <.custom_inline_code>row_direction</.custom_inline_code>
            is set to <.custom_inline_code>reverse</.custom_inline_code>, the positions are swapped, with the dismiss button appearing first and the content following it. This flexibility allows you to easily adjust the layout of your toast notifications, accommodating different design preferences or directional needs. The
            <.custom_inline_code>row_direction</.custom_inline_code>
            prop uses values like
            <.custom_inline_code>none</.custom_inline_code>
            for the standard flow and
            <.custom_inline_code>reverse</.custom_inline_code>
            for reversed alignment, providing customizable control over the visual structure of your toast notifications.
          </.cp>

          <.custom_block color="warning" position="left" class="my-8" border="medium">
            All components that have a dismiss button. When performing the operation,
            it sends an event to the server. for example
            <.custom_inline_code>handle_event("dismiss", params, socket)</.custom_inline_code>
          </.custom_block>

          <.custom_code_wrapper code_class="text-xs" code={@code_17}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-110"
              >
                Show Row Direction Normal (Info)
              </.button>
              <.button
                variant="outline"
                color="primary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-111"
              >
                Show Row Direction Reverse (Primary)
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-110"}
              id="toast_row_doc_110"
              row_direction="none"
              color="info"
              variant="default"
            >
              Row direction normal (Info) 110
            </.toast>

            <.toast
              :if={@toast_pos == "toast-example-111"}
              id="toast_row_doc_111"
              row_direction="reverse"
              color="primary"
              variant="default"
            >
              Row direction reverse (Primary) 111
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-fixed-prop">
            <.link patch={~p"/chelekom/docs/toast/#toast-fixed-prop"}>
              Fixed prop
            </.link>
          </.heading2>

          <.cp>
            The fixed prop controls whether the toast element remains fixed on the screen. When it is set to <.custom_inline_code>true</.custom_inline_code>, the toast stays in a fixed position, typically used for displaying notifications that remain visible as the user scrolls through the page. If set to <.custom_inline_code>false</.custom_inline_code>, the toast will behave according to its natural flow in the document, allowing it to scroll with the page. By default, this attribute is set to <.custom_inline_code>true</.custom_inline_code>.

            This property is especially useful when dealing with a toast group, as it allows multiple toasts to stay fixed together in one area of the screen, enhancing the user experience for displaying multiple notifications in a consistent manner.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_18} />

          <.heading2 margin="my-5" id="toast-font-weight">
            <.link patch={~p"/chelekom/docs/toast/#toast-font-weight"}>
              Font weight prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>font_weight</.custom_inline_code>
            prop in the Phoenix LiveView toast component allows you to customize the font weight of the text within the toast using Tailwind CSS classes. By default, it is set to <.custom_inline_code>font-normal</.custom_inline_code>, giving the text a regular weight. However, you can easily modify this by passing a different Tailwind class for font weight, such as
            <.custom_inline_code>font-bold</.custom_inline_code>
            to make the text bold, or other classes like
            <.custom_inline_code>font-silver</.custom_inline_code>
            or
            <.custom_inline_code>font-medium</.custom_inline_code>
            to adjust the thickness of the text as per your design needs. This flexibility allows for easy control over the typography within the toast, ensuring it aligns with the desired visual hierarchy.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_19}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-112"
              >
                Show Font medium
              </.button>
              <.button
                variant="outline"
                color="misc"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-113"
              >
                Show Font Thin
              </.button>
              <.button
                variant="outline"
                color="dawn"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-114"
              >
                Show Font Black
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-112"}
              id="toast_font_doc_112"
              font_weight="font-medium"
              color="primary"
              variant="default"
            >
              Toast with font medium
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-113"}
              id="toast_font_doc_113"
              font_weight="font-thin"
              color="primary"
              variant="default"
            >
              Toast with font thin
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-114"}
              id="toast_font_doc_114"
              font_weight="font-black"
              color="primary"
              variant="default"
            >
              Toast with font black
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-component">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-component"}>
              Toast group component
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>toast_group</.custom_inline_code>
            component in Phoenix LiveView is designed to manage and display multiple toast notifications in a cohesive and organized manner. This component allows developers to group several toast messages in one area of the screen, providing a unified space for notifications. Each toast within the group can be customized with individual properties such as <.custom_inline_code>space</.custom_inline_code>, <.custom_inline_code>vertical_space</.custom_inline_code>, <.custom_inline_code>horizontal_space</.custom_inline_code>, and more. By default, the toasts are stacked, and the entire group can be fixed in position ensuring that the notifications remain visible even when the user scrolls through the page.

            The toast_group component is ideal for scenarios where multiple messages need to be displayed without overwhelming the user interface. It maintains a clean and structured appearance, making it easier to manage notifications in a more organized, visually appealing way.
          </.cp>
          <.custom_code_wrapper code_class="text-xs" code={@code_20}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="primary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-115"
              >
                Show Font silver Toast
              </.button>
            </div>

            <.toast_group id="toast-group-example-1">
              <.toast
                :if={@toast_pos == "toast-example-115"}
                id="toast_group_doc_115"
                color="warning"
                variant="default"
                content_border="small"
                border_position="end"
                fixed={false}
              >
                <div>
                  This is a message with Font silver inside the toast group.
                </div>
              </.toast>

              <.toast
                :if={@toast_pos == "toast-example-115"}
                id="toast_group_doc_116"
                color="success"
                variant="default"
                content_border="small"
                border_position="end"
                fixed={false}
              >
                <div>
                  This is a message with Font Thin inside the toast group.
                </div>
              </.toast>

              <.toast
                :if={@toast_pos == "toast-example-115"}
                id="toast_group_doc_117"
                color="success"
                variant="default"
                content_border="small"
                border_position="end"
                fixed={false}
              >
                <div>
                  This is a message with Font Black inside the toast group.
                </div>
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-space">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-space"}>
              Space prop in Phoenix LiveView toast group component
            </.link>
          </.heading2>

          <.cp>
            The space prop in the Phoenix LiveView toast group component provides various spacing options, including <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. These options define the vertical spacing between individual toasts within the group, with increasing amounts of space from
            <.custom_inline_code>extra_small</.custom_inline_code>
            to <.custom_inline_code>extra_large</.custom_inline_code>. If no specific value is provided, the default is set to <.custom_inline_code>extra_small</.custom_inline_code>, but custom values can also be applied as needed.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_21}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="dawn"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-116"
              >
                Show Extra Large Space
              </.button>
              <.button
                variant="outline"
                color="success"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-117"
              >
                Show Extra small Space
              </.button>
            </div>

            <.toast_group id="toast-group-example-2" space="extra_large">
              <.toast
                :if={@toast_pos == "toast-example-116"}
                id="toast-example-118"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-116"}
                id="toast-example-119"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-116"}
                id="toast-example-120"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
            </.toast_group>
            <.toast_group id="toast-group-example-10" space="extra_small" vertical="top">
              <.toast
                :if={@toast_pos == "toast-example-117"}
                id="toast-example-140"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-117"}
                id="toast-example-141"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-117"}
                id="toast-example-142"
                color="danger"
                variant="default"
                fixed={false}
              >
                Toast inside toast group extra large space
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-vertical">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-vertical"}>
              Vertical prop
            </.link>
          </.heading2>

          <.cp>
            The vertical prop determines the vertical positioning of the toast group component. It accepts two values:
            <.custom_inline_code>top</.custom_inline_code>
            and <.custom_inline_code>bottom</.custom_inline_code>. By default, the toast group is positioned at the bottom of the screen. You can change this to
            <.custom_inline_code>top</.custom_inline_code>
            to display the group at the top, offering flexibility in where the notifications appear within the application.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_22}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="warning"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-118"
              >
                Show Toast Group
              </.button>
            </div>

            <.toast_group id="toast-group-example-3" vertical="top">
              <.toast
                :if={@toast_pos == "toast-example-118"}
                id="toast-example-121"
                color="info"
                variant="outline"
                fixed={false}
              >
                Toast inside toast group vertical top
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-118"}
                id="toast-example-122"
                color="info"
                variant="outline"
                fixed={false}
              >
                Toast inside toast group vertical top
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-vertical-space">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-vertical-space"}>
              Vertical space prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>vertical_space</.custom_inline_code>
            attribute in the Phoenix LiveView toast group component controls the space between vertically stacked toast notifications within the group. It offers flexibility with predefined options like <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. By default, the space is set to <.custom_inline_code>extra_small</.custom_inline_code>, but you can adjust it to maintain a clean and organized layout when displaying multiple toasts, ensuring they don’t overlap or look cluttered.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_23}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="dawn"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-119"
              >
                Extra Small Vertical Space
              </.button>
            </div>

            <.toast_group id="toast-group-example-4" vertical_space="extra_large">
              <.toast
                :if={@toast_pos == "toast-example-119"}
                id="toast-example-123"
                color="warning"
                variant="default"
                fixed={false}
              >
                Toast in group with Extra Small Vertical Space 1
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-119"}
                id="toast-example-124"
                color="warning"
                variant="default"
                fixed={false}
              >
                Toast in group with Extra Small Vertical Space 2
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-horizontal">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-horizontal"}>
              Horizontal prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>horizontal</.custom_inline_code>
            attribute in the Phoenix LiveView toast group component controls the horizontal alignment of the group on the screen. Options include <.custom_inline_code>left</.custom_inline_code>, <.custom_inline_code>right</.custom_inline_code>, and <.custom_inline_code>center</.custom_inline_code>. By default, the toast group appears on the <.custom_inline_code>right</.custom_inline_code>, but you can adjust it to
            <.custom_inline_code>left</.custom_inline_code>
            or
            <.custom_inline_code>center</.custom_inline_code>
            to change its alignment based on your design needs.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_24}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="secondary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-120"
              >
                Toast Vertical top horizontal left 1
              </.button>
            </div>

            <.toast_group id="toast-group-example-5" horizontal="left" vertical="top">
              <.toast
                :if={@toast_pos == "toast-example-120"}
                id="toast-example-125"
                color="dawn"
                variant="default"
                fixed={false}
              >
                Toast Vertical top horizontal left 1
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-120"}
                id="toast-example-126"
                color="dawn"
                variant="default"
                fixed={false}
              >
                Toast Vertical top horizontal left 2
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-group-horizontal-space">
            <.link patch={~p"/chelekom/docs/toast/#toast-group-horizontal-space"}>
              Horizontal space prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>horizontal_space</.custom_inline_code>
            attribute in the Phoenix LiveView toast group component defines the spacing between items in the horizontal direction within the toast group. It offers several predefined values such as <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. The default value is <.custom_inline_code>extra_small</.custom_inline_code>, but you can adjust it to control the spacing between horizontally aligned toasts in the group. This prop ensures flexibility and layout customization for different designs.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_25}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="secondary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-121"
              >
                Toast Vertical top horizontal left 1
              </.button>
            </div>

            <.toast_group
              id="toast-group-example-6"
              horizontal="left"
              vertical="bottom"
              horizontal_space="small"
            >
              <.toast
                :if={@toast_pos == "toast-example-121"}
                id="toast-example-127"
                color="primary"
                variant="default"
                fixed={false}
              >
                Toast Vertical top horizontal left 1
              </.toast>
              <.toast
                :if={@toast_pos == "toast-example-121"}
                id="toast-example-128"
                color="primary"
                variant="default"
                fixed={false}
              >
                Toast Vertical top horizontal left 2
              </.toast>
            </.toast_group>
          </.custom_code_wrapper>
        </:documentation_panel>

        <:props_panel>
          <.custom_search class="mb-16" />
          <div class="space-y-8">
            <h2 class="text-lg lg:text-2xl font-bold">Toast Component Props</h2>

            <.custom_table id="toast-component-props">
              <:header>
                <.table_th>Name</.table_th>

                <.table_th>Type</.table_th>

                <.table_th>Required</.table_th>

                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>

                <.table_td>string</.table_td>

                <.table_td>Yes</.table_td>

                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>fixed</.table_td>

                <.table_td>boolean</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines whether the toast is fixed. Default is <strong>true</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the style of the toast. Supported values: <strong>default</strong>, <strong>outline</strong>, <strong>shadow</strong>, <strong>bordered</strong>, <strong>gradient</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the color theme of the toast. Supported values: <strong>natural</strong>, <strong>primary</strong>, <strong>secondary</strong>, <strong>success</strong>, <strong>warning</strong>, <strong>danger</strong>, <strong>info</strong>, <strong>silver</strong>, <strong>misc</strong>, <strong>dawn</strong>. Default is <strong>natural</strong>.The
                  <strong>default</strong>
                  and <strong>bordered</strong>
                  variants have extra color options: <strong>dark</strong>
                  and <strong>white</strong>, which in both light mode and dark mode, these colors are always the same.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border style. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>rounded</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border radius. Default is <strong>medium</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>width</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the width of the toast. Default is <strong>medium</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines the space between items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the vertical positioning. Options are <strong>top</strong>
                  or <strong>bottom</strong>. Default is <strong>top</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical_space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines the vertical space between items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>horizontal</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the horizontal positioning. Options are <strong>left</strong>, <strong>right</strong>, or <strong>center</strong>. Default is <strong>right</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>horizontal_space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines the horizontal space between items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>font_weight</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the font weight. Default is <strong>font-normal</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom CSS class for additional styling. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>params</.table_td>

                <.table_td>map</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  A map of additional parameters used for element configuration. Default is <strong>%<%= "{" %>kind: "toast"}</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>rest</.table_td>

                <.table_td>global</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Global attributes that can define defaults which are merged with attributes provided by the caller.
                </.table_td>
              </:row>

              <:row>
                <.table_td>content_border</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the content border style. Default is <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border_position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border position style. Default is <strong>start</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>row_direction</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Determines row direction. Default is <strong>none</strong>.</.table_td>
              </:row>

              <:row>
                <.table_td>padding</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines padding for items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>
            </.custom_table>
          </div>

          <div class="space-y-8 mt-8">
            <h2 class="text-lg lg:text-2xl font-bold">Toast Group Component Props</h2>

            <.custom_table id="toast-group-component-props">
              <:header>
                <.table_th>Name</.table_th>

                <.table_th>Type</.table_th>

                <.table_th>Required</.table_th>

                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Space between items. Default is <strong>small</strong>.</.table_td>
              </:row>

              <:row>
                <.table_td>vertical</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines vertical positioning. Options are <strong>top</strong>
                  or <strong>bottom</strong>. Default is <strong>bottom</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical_space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines the space between vertical items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>wrapper_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Additional CSS classes to be added to the toast wrapper. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>content_wrapper_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Additional CSS classes to be added to the toast content wrapper. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>content_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Additional CSS classes to be added to the toast content. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>dismiss_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Additional CSS classes to be added to the toast dismiss button. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>dismiss_icon_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Additional CSS classes to be added to the toast dismiss icon. Default is an empty string.
                </.table_td>
              </:row>

              <:row>
                <.table_td>horizontal</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines horizontal positioning. Options are <strong>left</strong>, <strong>right</strong>, or <strong>center</strong>. Default is <strong>right</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>horizontal_space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines the space between horizontal items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom CSS class for additional styling. Default is an empty string.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/toast/#overview"}
            title="Overview of the toast component"
          />
          <:content
            link={~p"/chelekom/docs/toast/#default-variant-toast"}
            title="Default variant"
          />
          <:content
            link={~p"/chelekom/docs/toast/#outline-variant-toast"}
            title="Outline variant"
          />
          <:content link={~p"/chelekom/docs/toast/#shadow-variant-toast"} title="Shadow variant" />
          <:content
            link={~p"/chelekom/docs/toast/#bordered-variant-toast"}
            title="Bordered variant"
          />
          <:content
            link={~p"/chelekom/docs/toast/#gradient-variant-toast"}
            title="Gradient variant"
          />
          <:content link={~p"/chelekom/docs/toast/#toast-border-prop"} title="Border prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-rounded"} title="Rounded prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-space"} title="Space prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-padding"} title="Padding prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-width"} title="Width prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-vertical"} title="Vertical prop" />
          <:content
            link={~p"/chelekom/docs/toast/#toast-vertical-space"}
            title="Vertical space prop"
          />
          <:content link={~p"/chelekom/docs/toast/#toast-horizontal"} title="Horizontal prop" />
          <:content
            link={~p"/chelekom/docs/toast/#toast-horizontal-space"}
            title="Horizontal space prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-content-border"}
            title="Content border prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-border-position"}
            title="Border position prop"
          />
          <:content link={~p"/chelekom/docs/toast/#toast-row-reverse"} title="Row reverse prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-fixed-prop"} title="Fixed prop" />
          <:content link={~p"/chelekom/docs/toast/#toast-font-weight"} title="Font weight prop" />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-component"}
            title="Toast group component"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-space"}
            title="Toast group space prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-vertical"}
            title="Toast group vertical prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-vertical-space"}
            title="Toast group vertical space prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-horizontal"}
            title="Toast group horizontal prop"
          />
          <:content
            link={~p"/chelekom/docs/toast/#toast-group-horizontal-space"}
            title="Toast group horizontal space prop"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
