                Show Extra Large Horizontal Space (Success)
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-97"}
              id="toast_horizontal_space_doc_97"
              horizontal_space="extra_small"
              border_position="start"
              content_border="medium"
              color="info"
              variant="default"
            >
              Horizontal Space extra small (Info) 97
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-98"}
              id="toast_horizontal_space_doc_98"
              horizontal_space="small"
              border_position="start"
              content_border="medium"
              color="silver"
              variant="default"
            >
              Horizontal Space small (silver) 98
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-99"}
              id="toast_horizontal_space_doc_99"
              horizontal_space="medium"
              border_position="start"
              content_border="medium"
              color="primary"
              variant="default"
            >
              Horizontal Space medium (Primary) 99
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-100"}
              id="toast_horizontal_space_doc_100"
              horizontal_space="large"
              border_position="start"
              content_border="medium"
              color="danger"
              variant="default"
            >
              Horizontal Space large (Danger) 100
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-101"}
              id="toast_horizontal_space_doc_101"
              horizontal_space="extra_large"
              border_position="start"
              content_border="medium"
              color="success"
              variant="default"
            >
              Horizontal Space extra large (Success) 101
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-content-border">
            <.link patch={~p"/chelekom/docs/toast/#toast-content-border"}>
              Content border prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>content_border</.custom_inline_code>
            attribute in the Phoenix LiveView component determines the size and style of the content border within the toast. It offers options like <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, <.custom_inline_code>extra_large</.custom_inline_code>, and <.custom_inline_code>none</.custom_inline_code>. These options adjust the width of the border, allowing customization from
            <.custom_inline_code>extra_small</.custom_inline_code>
            to <.custom_inline_code>extra_large</.custom_inline_code>. Setting the attribute to
            <.custom_inline_code>none</.custom_inline_code>
            hides the border entirely. If no value is provided, it defaults to <.custom_inline_code>none</.custom_inline_code>, but custom values can also be used as needed. Additionally, if the
            <.custom_inline_code>@content_border</.custom_inline_code>
            is not set to <.custom_inline_code>none</.custom_inline_code>, the styles defined by
            <.custom_inline_code>border_position</.custom_inline_code>
            will not apply.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_15}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="info"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-102"
              >
                Show Extra Small Content Border
              </.button>
              <.button
                variant="outline"
                color="silver"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-103"
              >
                Show Small Content Border
              </.button>
              <.button
                variant="outline"
                color="primary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-104"
              >
                Show Medium Content Border
              </.button>
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-105"
              >
                Show Large Content Border
              </.button>
              <.button
                variant="outline"
                color="success"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-106"
              >
                Show Extra Large Content Border
