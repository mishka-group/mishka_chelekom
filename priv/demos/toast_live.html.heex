              </.button>
              <.button
                variant="outline"
                color="success"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-82"
              >
                Show Extra Large Width
              </.button>
              <.button
                variant="outline"
                color="warning"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-83"
              >
                Show Full Width
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-78"}
              id="toast_width_doc_78"
              width="extra_small"
              color="info"
              variant="default"
            >
              Width extra small (Info) 78
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-79"}
              id="toast_width_doc_79"
              width="small"
              color="silver"
              variant="default"
            >
              Width small (silver) 79
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-80"}
              id="toast_width_doc_80"
              width="medium"
              color="primary"
              variant="default"
            >
              Width medium (Primary) 80
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-81"}
              id="toast_width_doc_81"
              width="large"
              color="danger"
              variant="default"
            >
              Width large (Danger) 81
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-82"}
              id="toast_width_doc_82"
              width="extra_large"
              color="success"
              variant="default"
            >
              Width extra large (Success) 82
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-83"}
              id="toast_width_doc_83"
              width="full"
              color="silver"
              variant="default"
            >
              Width full (silver) 83
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-vertical">
            <.link patch={~p"/chelekom/docs/toast/#toast-vertical"}>
              Vertical prop
            </.link>
          </.heading2>

          <.cp>
            The vertical prop determines the vertical positioning of the toast component. It accepts two values:
            <.custom_inline_code>top</.custom_inline_code>
            and <.custom_inline_code>bottom</.custom_inline_code>. By default, the toast is positioned at the top of the screen. You can change this to
            <.custom_inline_code>bottom</.custom_inline_code>
            to display the toast at the bottom, offering flexibility in where the notifications appear within the application.
          </.cp>
          <.custom_code_wrapper code_class="text-xs" code={@code_11}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="info"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-84"
              >
                Show Toast (Top)
              </.button>
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-85"
              >
                Show Toast (Bottom)
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-84"}
              id="toast_vertical_doc_84"
              vertical="top"
              color="info"
              variant="default"
            >
              Toast at Top (Info) 84
            </.toast>

            <.toast
              :if={@toast_pos == "toast-example-85"}
              id="toast_vertical_doc_85"
              vertical="bottom"
              color="danger"
              variant="default"
            >
              Toast at Bottom (Danger) 85
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-vertical-space">
            <.link patch={~p"/chelekom/docs/toast/#toast-vertical-space"}>
              Vertical space prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>vertical_space</.custom_inline_code>
            attribute in the Phoenix LiveView toast component controls the amount of space between vertically stacked toast notifications. It offers flexibility with various predefined options like <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>, allowing developers to manage the spacing between toasts to create a visually pleasing and organized layout. By default, the space between items is set to <.custom_inline_code>extra_small</.custom_inline_code>, but you can adjust it according to your design preferences to ensure the toast notifications don't overlap or appear cluttered when multiple toasts are displayed. This helps improve readability and user experience by maintaining a clear, well-spaced arrangement.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_12}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="info"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-86"
              >
                Show Extra Small Vertical Space (Info)
              </.button>
              <.button
                variant="outline"
                color="silver"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-87"
              >
                Show Small Vertical Space (silver)
              </.button>
              <.button
                variant="outline"
                color="primary"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-88"
              >
                Show Medium Vertical Space (Primary)
              </.button>
              <.button
                variant="outline"
                color="danger"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-89"
              >
                Show Large Vertical Space (Danger)
              </.button>
              <.button
                variant="outline"
                color="success"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-90"
              >
                Show Extra Large Vertical Space (Success)
              </.button>
            </div>

            <.toast
              :if={@toast_pos == "toast-example-86"}
              id="toast_vertical_space_doc_86"
              vertical_space="extra_small"
              color="info"
              variant="default"
            >
              Vertical Space extra small (Info) 86
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-87"}
              id="toast_vertical_space_doc_87"
              vertical_space="small"
              color="silver"
              variant="default"
            >
              Vertical Space small (silver) 87
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-88"}
              id="toast_vertical_space_doc_88"
              vertical_space="medium"
              color="primary"
              variant="default"
            >
              Vertical Space medium (Primary) 88
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-89"}
              id="toast_vertical_space_doc_89"
              vertical_space="large"
              color="danger"
              variant="default"
            >
              Vertical Space large (Danger) 89
            </.toast>
            <.toast
              :if={@toast_pos == "toast-example-90"}
              id="toast_vertical_space_doc_90"
              vertical_space="extra_large"
              color="success"
              variant="default"
            >
              Vertical Space extra large (Success) 90
            </.toast>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="toast-horizontal">
            <.link patch={~p"/chelekom/docs/toast/#toast-horizontal"}>
              Horizontal prop
            </.link>
          </.heading2>

          <.cp>
            The horizontal attribute in the Phoenix LiveView toast component controls the horizontal alignment of the toast on the screen. By providing options like <.custom_inline_code>left</.custom_inline_code>, <.custom_inline_code>right</.custom_inline_code>, and <.custom_inline_code>center</.custom_inline_code>, developers can customize where the toast appears horizontally. The default setting is <.custom_inline_code>right</.custom_inline_code>, positioning the toast on the right side of the screen. However, this can be changed to
            <.custom_inline_code>left</.custom_inline_code>
            for left-side positioning or
            <.custom_inline_code>center</.custom_inline_code>
            for centering the toast in the middle of the screen. This flexibility allows for better control over the toast's appearance and alignment, making it suitable for various design and layout needs.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_13}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                variant="outline"
                color="info"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-91"
              >
                Show Left (Info, Top)
              </.button>
              <.button
                variant="outline"
                color="dawn"
                size="small"
                phx-click="toast_position"
                phx-value-pos="toast-example-92"
              >
                Show Center (dawn, Top)
              </.button>
              <.button
                variant="outline"
