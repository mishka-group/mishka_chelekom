                  <div class="flex items-center gap-5 mt-8">
                    <.rating select={4} size="medium" />
                    <.badge
                      variant="bg-amber-200 text-gray-900 border-amber-200"
                      rounded="medium"
                      size="py-0.5 px-3"
                      class="leading-6"
