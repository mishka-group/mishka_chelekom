                  </div>
                  <div class="flex justify-end items-center mt-3">
                    <.button
                      size="py-1.5 px-8"
                      font_weight="font-bold"
                      variant="default"
                      color="misc"
                    >
                      Add image to cart
                    </.button>
                  </div>
                </.card_content>
              </.card>
              <.card rounded="small" variant="default" color="dark">
                <.card_media
                  src={~p"/images/mishka-chelekom-media-1.jpg"}
