            title="Gradient variant"
          />
          <:content link={~p"/chelekom/docs/footer/#footer-rounded"} title="Rounded prop" />
          <:content link={~p"/chelekom/docs/footer/#footer-border"} title="Border prop" />
          <:content link={~p"/chelekom/docs/footer/#footer-space"} title="Space prop" />
          <:content link={~p"/chelekom/docs/footer/#footer-padding"} title="Padding prop" />
          <:content link={~p"/chelekom/docs/footer/#footer-max-width"} title="Max width" />
          <:content link={~p"/chelekom/docs/footer/#footer-text-position"} title="Text position" />
          <:content link={~p"/chelekom/docs/footer/#footer-font-weight-prop"} title="Font weight" />
          <:content
            link={~p"/chelekom/docs/footer/#footer-section-component"}
            title="Footer section"
          />
          <:content
            link={~p"/chelekom/docs/footer/#footer-section-space"}
            title="Footer section space prop"
          />
          <:content
            link={~p"/chelekom/docs/footer/#footer-section-padding"}
            title="Footer section padding prop"
          />
          <:content
            link={~p"/chelekom/docs/footer/#footer-section-text-position"}
            title="Footer section text position"
          />
          <:content
            link={~p"/chelekom/docs/footer/#footer-section-font-weight-prop"}
            title="Footer section font weight"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
