          <.heading2 margin="my-5" id="sidebar-hide-position-prop">
            <.link patch={~p"/chelekom/docs/sidebar/#sidebar-hide-position-prop"}>
              Hide position prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>hide_position</.custom_inline_code>
            attribute determines the direction the sidebar hides on mobile, with
            <.custom_inline_code>"left"</.custom_inline_code>
            sliding it off to the left and
            <.custom_inline_code>"right"</.custom_inline_code>
            sliding it off to the right for a smooth user experience.
          </.cp>

          <.custom_code_wrapper
            elements_class="flex gap-10 items-center justify-center"
            code={@code_5}
          >
            <.button
              size="small"
              color="secondary"
              variant="outline"
              class="hidden md:flex"
              phx-click="sidebar_position"
              phx-value-pos="sidebar-example-9"
