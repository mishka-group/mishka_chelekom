          <.heading2 margin="my-5" id="sidebar-position-prop">
            <.link patch={~p"/chelekom/docs/sidebar/#sidebar-position-prop"}>
              Position prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>position</.custom_inline_code>
            prop supports values like
            <.custom_inline_code>start</.custom_inline_code>
            and <.custom_inline_code>end</.custom_inline_code>, with the default being <.custom_inline_code>start</.custom_inline_code>. Based on the text direction (LTR or RTL), this positions the sidebar at the start of the page.
          </.cp>

          <.custom_code_wrapper
            elements_class="flex gap-10 items-center justify-center"
            code={@code_4}
          >
            <.button
              size="small"
              color="info"
