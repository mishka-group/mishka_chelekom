          <.heading2 margin="my-5" id="sidebar-on-small-devices">
            <.link patch={~p"/chelekom/docs/sidebar/#sidebar-on-small-devices"}>
              On small devices
            </.link>
          </.heading2>

          <.cp>
            You can add the
            <.custom_inline_code>
              Sidebar.show_sidebar("unique_id", "hide_position")
            </.custom_inline_code>
            function to a button, allowing you to toggle the sidebar on smaller devices.
          </.cp>

          <.custom_code_wrapper
            elements_class="flex gap-10 items-center justify-center"
            code={@code_6}
          />
          <.heading2 margin="my-5" id="minimize-sidebar">
            <.link patch={~p"/chelekom/docs/sidebar/#minimize-sidebar"}>
              Minimize prop
            </.link>
          </.heading2>

          <.cp class="mb-5">
            Controls whether the minimize button is shown.
            Accepts a boolean value.
            Default is <.custom_inline_code>false</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper
            elements_class="flex gap-10 items-center justify-center"
            code={@code_7}
          >
            <.button
              size="small"
              phx-click="sidebar_position"
              phx-value-pos="sidebar-example-11"
              class="hidden md:flex"
            >
              show sidebar
            </.button>

            <.sidebar
              :if={@sidebar_pos == "sidebar-example-11"}
              id="sidebar-example-11"
              border="extra_small"
              hide_position="left"
              minimize
            >
              <:item
                icon="hero-home"
                icon_class="size-6"
                label="Dashboard"
                link="/dashboard"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-envelope"
                icon_class="size-6"
                label="Messages"
                link="/messages"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-star"
                icon_class="size-6"
                label="Bookmarks"
                link="/bookmarks"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-user-group"
                icon_class="size-6"
                label="Teams"
                link="/teams"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-calendar"
                icon_class="size-6"
                label="Calendar"
                link="/calendar"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-cog-6-tooth"
                icon_class="size-6"
                label="Settings"
                link="/settings"
                class="mb-3 hover:opacity-95"
              />
              <:item
                icon="hero-user-circle"
                icon_class="size-6"
                label="Profile"
                link="/profile"
                class="mb-3 hover:opacity-95"
              />
            </.sidebar>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="item-slot">
            <.link patch={~p"/chelekom/docs/sidebar/#item-slot"}>
              Sidebar item slot
            </.link>
          </.heading2>

          <.cp class="mb-5">
            Slot for defining individual sidebar navigation items.

            Each
            <.custom_inline_code>:item</.custom_inline_code>
            can have the following attributes:
            <ul class="mt-4 list-disc list-inside space-y-1">
              <li>
                <.custom_inline_code>icon</.custom_inline_code>
                – Icon name to display.
              </li>
              <li>
                <.custom_inline_code>icon_class</.custom_inline_code>
                – CSS class for the icon element.
              </li>
              <li>
                <.custom_inline_code>label</.custom_inline_code>
                – Text label shown in the item.
              </li>
              <li>
                <.custom_inline_code>label_class</.custom_inline_code>
                – CSS class for the label text.
              </li>
              <li>
                <.custom_inline_code>link</.custom_inline_code>
                – The URL the item links to.
              </li>
              <li>
                <.custom_inline_code>class</.custom_inline_code>
                – CSS class for the whole item container.
              </li>
            </ul>
            This slot can be used multiple times to render a list of navigational links inside the sidebar.
          </.cp>
          <.custom_code_wrapper
            elements_class="flex gap-10 items-center justify-center"
            code={@code_8}
          />
        </:documentation_panel>

        <:props_panel>
          <.custom_search class="mb-16" />
          <div class="space-y-8">
            <h2 class="text-lg lg:text-2xl font-bold">Sidebar Component Props</h2>

            <.custom_table id="sidebar-component-table">
              <:header>
                <.table_th>Name</.table_th>

                <.table_th>Type</.table_th>

                <.table_th>Required</.table_th>

                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>

                <.table_td>string</.table_td>

                <.table_td>Yes</.table_td>

                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the style of the card. Supported values: <strong>base</strong>, <strong>default</strong>, <strong>outline</strong>, <strong>transparent</strong>, <strong>shadow</strong>, <strong>bordered</strong>, <strong>gradient</strong>. <strong>bawse is default</strong>,
                </.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the color theme of the card. Supported values: <strong>natural</strong>, <strong>primary</strong>, <strong>secondary</strong>, <strong>success</strong>, <strong>warning</strong>, <strong>danger</strong>, <strong>info</strong>, <strong>silver</strong>, <strong>misc</strong>, <strong>dawn</strong>. Default is <strong>natural</strong>.The
                  <strong>default</strong>
                  and <strong>bordered</strong>
                  variants have extra color options: <strong>dark</strong>
                  and <strong>white</strong>, which in both light mode and dark mode, these colors are always the same.
                </.table_td>
              </:row>

              <:row>
                <.table_td>size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the overall size of the elements, including padding, font size, and other items. Default is <strong>large</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines border style. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the element position. Default is <strong>start</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>hide_position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines what position should be hidden. Values: <strong>left</strong>, <strong>right</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom CSS class for additional styling. Default is <strong>nil</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>on_hide</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom JS module for the on_hide action.
                </.table_td>
              </:row>

              <:row>
                <.table_td>on_show</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom JS module for the on_show action.
                </.table_td>
              </:row>

              <:row>
                <.table_td>on_hide_away</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Custom JS module for the on_hide_away action.
                </.table_td>
              </:row>

              <:row>
                <.table_td>minimize</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines if the minimize button is shown. Default is <strong>false</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>minimize_icon</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Icon used for the minimize button. Default is <strong>hero-arrow-left-start-on-rectangle</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>minimize_label</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Label displayed next to the minimize icon.
                </.table_td>
              </:row>

              <:row>
                <.table_td>minimize_label_class</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Additional CSS classes for customizing the minimize label appearance. Default is <strong>text-xs</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>minimize_icon_class</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Additional CSS classes for customizing the minimize icon appearance. Default is <strong>size-5</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:icon]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Icon name to display for each sidebar item.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:icon_class]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  CSS class for the icon.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:label]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Text label for the menu item.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:label_class]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  CSS class for the label text.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:link]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  URL for the item link.
                </.table_td>
              </:row>

              <:row>
                <.table_td>item[:class]</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  CSS class for the entire item.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/sidebar/#overview"}
            title="Overview of Sidebar Component"
          />

          <:content
            link={~p"/chelekom/docs/sidebar/#sidebar-js-modules"}
            title="About LiveView JS module commands"
          />

          <:content
            link={~p"/chelekom/docs/sidebar/#sidebar-variant-colors"}
            title="Sidebar variant and color props"
          />

          <:content link={~p"/chelekom/docs/sidebar/#sidebar-border"} title="Border prop" />

          <:content link={~p"/chelekom/docs/sidebar/#sidebar-size"} title="Size prop" />

          <:content
            link={~p"/chelekom/docs/sidebar/#sidebar-position-prop"}
            title="Position prop"
          />

          <:content
            link={~p"/chelekom/docs/sidebar/#sidebar-hide-position-prop"}
            title="Hide position prop"
          />

          <:content
            link={~p"/chelekom/docs/sidebar/#sidebar-on-small-devices"}
            title="On small devices"
          />

          <:content link={~p"/chelekom/docs/sidebar/#minimize-sidebar"} title="Minimize sidebar" />

          <:content link={~p"/chelekom/docs/sidebar/#item-slot"} title="Item slot" />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
