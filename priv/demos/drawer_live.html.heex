        <:props_panel>
          <.custom_search class="mb-16" />
          <div class="space-y-8">
            <h2 class="text-lg lg:text-2xl font-bold">Drawer component props</h2>

            <.custom_table id="drawer-component-table">
              <:header>
                <.table_th>Name</.table_th>

                <.table_th>Type</.table_th>

                <.table_th>Required</.table_th>

                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>

                <.table_td>string</.table_td>

                <.table_td>Yes</.table_td>

                <.table_td>
                  A unique identifier is used to manage state and interaction.
                </.table_td>
              </:row>

              <:row>
                <.table_td>title</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Specifies the title of the element.</.table_td>
              </:row>

              <:row>
                <.table_td>title_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Determines custom class for the title.</.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the style of the drawer. Supported values: <strong>base</strong>, <strong>default</strong>, <strong>outline</strong>, <strong>transparent</strong>, <strong>bordered</strong>, <strong>gradient</strong>. Default: <strong>default</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the color theme of the drawer. Supported values include: <strong>base</strong>, <strong>natural</strong>, <strong>primary</strong>, <strong>secondary</strong>, <strong>success</strong>, <strong>warning</strong>, <strong>danger</strong>, <strong>info</strong>, <strong>misc</strong>, <strong>dawn</strong>. Default: <strong>natural</strong>. The
                  <strong>default</strong>
                  and <strong>bordered</strong>
                  variants have extra color options: <strong>dark</strong>
                  and <strong>white</strong>, which in both light mode and dark mode, these colors are always the same.
                </.table_td>
              </:row>

              <:row>
                <.table_td>size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the overall size of the element, including padding, font size, and other items. Default: <strong>large</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border style. Default: <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>rounded</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Determines the border radius.</.table_td>
              </:row>

              <:row>
                <.table_td>position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the element position. Default: <strong>left</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling.</.table_td>
              </:row>

              <:row>
                <.table_td>on_hide</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom JS module for the on_hide action.</.table_td>
              </:row>

              <:row>
                <.table_td>on_show</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom JS module for the on_show action.</.table_td>
              </:row>

              <:row>
                <.table_td>close_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling to close button.</.table_td>
              </:row>

              <:row>
                <.table_td>content_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling to content.</.table_td>
              </:row>

              <:row>
                <.table_td>wrapper_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling to wrapper.</.table_td>
              </:row>

              <:row>
                <.table_td>overlay_class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling to overlay.</.table_td>
              </:row>

              <:row>
                <.table_td>on_hide_away</.table_td>

                <.table_td>JS</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom JS module for the on_hide_away action.</.table_td>
              </:row>

              <:row>
                <.table_td>show</.table_td>

                <.table_td>boolean</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Specifies whether to show the element. Default: <strong>false</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>header</.table_td>

                <.table_td>slot</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Defines a slot for the drawer's header. Accepts HEEx content.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/drawer/#overview"}
            title="Overview of the drawer component"
          />
          <:content link={~p"/chelekom/docs/drawer/#drawer-js-modules"} title="About js modules" />
          <:content link={~p"/chelekom/docs/drawer/#base-drawer"} title="Base variant" />
          <:content
            link={~p"/chelekom/docs/drawer/#default-variant-drawer"}
            title="Default Variant"
          />
          <:content
            link={~p"/chelekom/docs/drawer/#outline-variant-drawer"}
            title="Outline Variant"
          />
          <:content
            link={~p"/chelekom/docs/drawer/#transparent-variant-drawer"}
            title="Transparent Variant"
          />
          <:content
            link={~p"/chelekom/docs/drawer/#bordered-variant-drawer"}
            title="Bordered Variant"
          />
          <:content
            link={~p"/chelekom/docs/drawer/#gradient-variant-drawer"}
            title="Gradient Variant"
          />
          <:content link={~p"/chelekom/docs/drawer/#drawer-border"} title="Border prop" />
          <:content link={~p"/chelekom/docs/drawer/#drawer-size"} title="Size prop" />
          <:content
            link={~p"/chelekom/docs/drawer/#drawer-title-prop"}
            title="Title and title class prop"
          />
          <:content link={~p"/chelekom/docs/drawer/#drawer-position-prop"} title="Position prop" />
          <:content link={~p"/chelekom/docs/drawer/#drawer-show-prop"} title="Show prop" />
          <:content link={~p"/chelekom/docs/drawer/#drawer-header-slot"} title="Header slot" />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
