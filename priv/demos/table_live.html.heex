<Layouts.app flash={@flash}>
  <div class="lg:grid lg:grid-cols-12 mt-5 max-w-5xl mx-auto">
    <.custom_nav active="chelekom-docs-table" />
    <div class="lg:col-span-10">
      <.custom_info
        title="Table"
        description="Table component for Phoenix LiveView with support for styling, borders, text alignment, padding, and dynamic headers, footers, and cells."
        mix="mix mishka.ui.gen.component table"
        github="https://github.com/mishka-group/mishka_chelekom/blob/master/priv/components/table.eex"
        tags={["Component", "Stateless"]}
      />
      <.custom_tab id="chelekom-table-tab">
        <:documentation_panel>
          <.heading2 class="mb-5" id="overview">
            <.link patch={~p"/chelekom/docs/table/#overview"}>
              Overview of the Phoenix LiveView table Component
            </.link>
          </.heading2>

          <.cp>
            The <strong>Mishka Chelekom table</strong>
            component is a versatile and customizable <strong>Phoenix LiveView</strong>
            tool for displaying data in a structured table format.
          </.cp>

          <.custom_code_wrapper elements_class="space-y-5">
            <.table
              header_border="extra_small"
              rows_border="extra_small"
              cols_border="extra_small"
              rounded="large"
              variant="base_hoverable"
              id="example-1"
            >
              <:header>Name</:header>

              <:header>Role</:header>

              <:header>Status</:header>

              <:header>Actions</:header>

              <.tr>
                <.td>
                  <div class="flex items-center gap-3">
                    <div class="shrink-0">
                      <.avatar size="medium" rounded="full" src={~p"/images/mona-aghili.jpg"} />
                    </div>
                    <div>
                      <div class="mb-1.5 text-[13px] font-semiblod">Mona Aghili</div>
                      <div class="text-[12px] text-gray-500 dark:text-gray-400">
                        mona@mishka.life
                      </div>
                    </div>
                  </div>
                </.td>

                <.td>
                  Front-end developer
                </.td>

                <.td>
                  <.badge variant="bordered" rounded="full" color="danger">Offline</.badge>
                </.td>

                <.td>
                  <div class="flex items-center gap-2 justify-between">
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" /><circle
                          cx="12"
                          cy="12"
                          r="3"
                        />
                      </svg>
                    </button>
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="m10 10-6.157 6.162a2 2 0 0 0-.5.833l-1.322 4.36a.5.5 0 0 0 .622.624l4.358-1.323a2 2 0 0 0 .83-.5L14 13.982" /><path d="m12.829 7.172 4.359-4.346a1 1 0 1 1 3.986 3.986l-4.353 4.353" /><path d="m15 5 4 4" /><path d="m2 2 20 20" />
                      </svg>
                    </button>
                    <button class="leading-5 text-rose-300 dark:text-rose-600">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line
                          x1="10"
                          x2="10"
                          y1="11"
                          y2="17"
                        /><line x1="14" x2="14" y1="11" y2="17" />
                      </svg>
                    </button>
                  </div>
                </.td>
              </.tr>

              <.tr>
                <.td>
                  <div class="flex items-center gap-3">
                    <div class="shrink-0">
                      <.avatar size="medium" rounded="full" src={~p"/images/arian-alijani.jpg"} />
                    </div>
                    <div>
                      <div class="mb-1.5 text-[13px] font-semiblod">Arian Alijani</div>
                      <div class="text-[12px] text-gray-500 dark:text-gray-400">
                        arian@mishka.tools
                      </div>
                    </div>
                  </div>
                </.td>

                <.td>QA Engineer</.td>

                <.td>
                  <.badge variant="bordered" rounded="full" color="warning">Vacation</.badge>
                </.td>

                <.td>
                  <div class="flex items-center gap-2 justify-between">
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
