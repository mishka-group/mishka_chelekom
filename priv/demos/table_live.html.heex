          <.heading2 margin="my-5" id="table-components">
            <.link patch={~p"/chelekom/docs/table/#table-components"}>
              Table th, td, tr components
            </.link>
          </.heading2>

          <.cp>
            You can use the <.custom_inline_code>tr</.custom_inline_code>, <.custom_inline_code>th</.custom_inline_code>, and
            <.custom_inline_code>td</.custom_inline_code>
            components to create table rows, table headers, and table data cells respectively. These components allow for customizable class attributes and styling, helping you structure your table efficiently within Phoenix LiveView.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_14}>
            <.table
              header_border="extra_small"
              rows_border="extra_small"
