          <.heading2 margin="my-5" id="table-examples">
            <.link patch={~p"/chelekom/docs/table/#table-examples"}>
              Integrating Other Mishka Chelekom Components Within the Table
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="space-y-5">
            <.table
              header_border="extra_small"
