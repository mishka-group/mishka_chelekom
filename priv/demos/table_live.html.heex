                        />
                      </svg>
                    </button>
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="m10 10-6.157 6.162a2 2 0 0 0-.5.833l-1.322 4.36a.5.5 0 0 0 .622.624l4.358-1.323a2 2 0 0 0 .83-.5L14 13.982" /><path d="m12.829 7.172 4.359-4.346a1 1 0 1 1 3.986 3.986l-4.353 4.353" /><path d="m15 5 4 4" /><path d="m2 2 20 20" />
                      </svg>
                    </button>
                    <button class="leading-5 text-rose-300 dark:text-rose-600">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line
                          x1="10"
                          x2="10"
                          y1="11"
                          y2="17"
                        /><line x1="14" x2="14" y1="11" y2="17" />
                      </svg>
                    </button>
                  </div>
                </.td>
              </.tr>

              <.tr>
                <.td>
                  <div class="flex items-center gap-3">
                    <div class="shrink-0">
                      <.avatar
                        size="medium"
                        rounded="full"
                        src={~p"/images/shahryar-tavakkoli.jpg"}
                      />
                    </div>
                    <div>
                      <div class="mb-1.5 text-[13px] font-semiblod">Shahryar Tavakkoli</div>
                      <div class="text-[12px] text-gray-500 dark:text-gray-400">
                        shahryar@mishka.tools
                      </div>
                    </div>
                  </div>
                </.td>

                <.td>Fullstack developer</.td>

                <.td>
                  <.badge variant="bordered" rounded="full" color="success">Active</.badge>
                </.td>

                <.td>
                  <div class="flex items-center gap-2 justify-between">
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" /><circle
                          cx="12"
                          cy="12"
                          r="3"
                        />
                      </svg>
                    </button>
                    <button class="leading-5 text-gray-500 dark:text-gray-700">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="m10 10-6.157 6.162a2 2 0 0 0-.5.833l-1.322 4.36a.5.5 0 0 0 .622.624l4.358-1.323a2 2 0 0 0 .83-.5L14 13.982" /><path d="m12.829 7.172 4.359-4.346a1 1 0 1 1 3.986 3.986l-4.353 4.353" /><path d="m15 5 4 4" /><path d="m2 2 20 20" />
                      </svg>
                    </button>
                    <button class="leading-5 text-rose-300 dark:text-rose-600">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[17px]"
                      >
                        <path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line
                          x1="10"
                          x2="10"
                          y1="11"
                          y2="17"
                        /><line x1="14" x2="14" y1="11" y2="17" />
                      </svg>
                    </button>
                  </div>
                </.td>
              </.tr>
            </.table>

            <.table color="base" variant="base_hoverable" rounded="small" id="example-2">
              <:header>
                <.checkbox_field
                  name="table-checkbox-1"
                  value=""
                  size="medium"
                  id="table-checkbox-1"
                  color="misc"
                />
              </:header>

              <:header>Name</:header>

              <:header>Age</:header>

              <:header>Address</:header>

              <:header>Action</:header>

              <.tr>
                <.td>
                  <.checkbox_field
                    name="table-checkbox-2"
                    value=""
                    size="medium"
                    id="table-checkbox-2"
                    color="misc"
                  />
                </.td>

                <.td>
                  Alice Johnson
                </.td>

                <.td>34</.td>

                <.td>
                  New York, No. 5 Broadway
                </.td>

                <.td>
                  <button>Edit</button>
                </.td>
              </.tr>

              <.tr>
                <.td>
                  <.checkbox_field
                    name="table-checkbox-3"
                    value=""
                    size="medium"
                    id="table-checkbox-3"
                    color="misc"
                    checked
                  />
                </.td>
                <.td>
                  Michael Scott
                </.td>

                <.td>45</.td>

                <.td>
                  Scranton, No. 2 Paper Road
                </.td>

                <.td>
                  <button>Edit</button>
                </.td>
              </.tr>

              <.tr>
                <.td>
                  <.checkbox_field
                    name="table-checkbox-4"
                    value=""
                    size="medium"
                    id="table-checkbox-4"
                    color="misc"
                  />
                </.td>
                <.td>
                  Emily Carter
                </.td>

                <.td>29</.td>

                <.td>
                  San Francisco, No. 10 Bay Street
                </.td>

                <.td>
                  <button>Edit</button>
                </.td>
              </.tr>
            </.table>
          </.custom_code_wrapper>

          <.cp margin="mt-5">
            This
            <strong>
              <.link
                title="Phoenix LiveView component"
                class="transition-colors hover:text-[#448D96]"
                navigate={~p"/chelekom"}
              >
                Phoenix LiveView component
              </.link>
            </strong>
            also offers thematic colors, icon support, and responsive design, ensuring a seamless user experience for both desktop and mobile users. It is perfect for any project that requires an organized, visually appealing table to display and manage data effectively.
          </.cp>

          <.custom_block position="left" color="success" class="my-8" border="medium">
            <.cp>
              By using the class prop, you can apply custom classes or Tailwind CSS classes to customize the appearance and behavior of the components, allowing for flexible design changes.
            </.cp>
          </.custom_block>

          <.heading2 margin="my-5" id="table-variant-colors">
            <.link patch={~p"/chelekom/docs/table/#table-variant-colors"}>
              Table variant and color props
            </.link>
          </.heading2>

          <.cp class="my-8">
            The <.link navigate={~p"/chelekom/docs/table"}>table component</.link>
            supports seven distinct variants: <.custom_inline_code>base</.custom_inline_code>, <.custom_inline_code>default</.custom_inline_code>, <.custom_inline_code>outline</.custom_inline_code>, <.custom_inline_code>shadow</.custom_inline_code>, <.custom_inline_code>bordered</.custom_inline_code>, <.custom_inline_code>transparent</.custom_inline_code>, <.custom_inline_code>separated</.custom_inline_code>, <.custom_inline_code>hoverable</.custom_inline_code>, and <.custom_inline_code>stripped</.custom_inline_code>. Each variant can be styled with a variety of colors, including <.custom_inline_code>base</.custom_inline_code>, <.custom_inline_code>white</.custom_inline_code>, <.custom_inline_code>primary</.custom_inline_code>, <.custom_inline_code>secondary</.custom_inline_code>, <.custom_inline_code>dark</.custom_inline_code>, <.custom_inline_code>success</.custom_inline_code>, <.custom_inline_code>warning</.custom_inline_code>, <.custom_inline_code>danger</.custom_inline_code>, <.custom_inline_code>info</.custom_inline_code>, <.custom_inline_code>silver</.custom_inline_code>, <.custom_inline_code>misc</.custom_inline_code>, <.custom_inline_code>dawn</.custom_inline_code>, and <.custom_inline_code>silver</.custom_inline_code>.
          </.cp>

