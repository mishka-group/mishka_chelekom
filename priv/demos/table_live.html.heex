          <:content link={~p"/chelekom/docs/table/#table-rows-border"} title="Rows border prop" />
          <:content link={~p"/chelekom/docs/table/#table-cols-border"} title="Cols border prop" />
          <:content link={~p"/chelekom/docs/table/#table-fixed"} title="Fixed layout table" />
          <:content link={~p"/chelekom/docs/table/#table-header-slot"} title="Table header slot" />
          <:content
