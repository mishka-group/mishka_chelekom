            title="Table footer icon and icon class"
          />
          <:content
            link={~p"/chelekom/docs/table/#table-components"}
            title="Table th, td, tr components"
          />
          <:content
            link={~p"/chelekom/docs/table/#table-pagination"}
            title="Use pagination with tables"
          />
          <:content
            link={~p"/chelekom/docs/table/#table-examples"}
            title="Integrating Components Within the Table"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
