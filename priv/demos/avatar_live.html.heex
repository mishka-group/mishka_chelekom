              </.avatar>
              <.avatar id="avatar58" size="extra_large" rounded="full" color="misc">
                <:icon name="hero-bell-alert" />
              </.avatar>
            </div>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="shadow-prop">
            <.link patch={~p"/chelekom/docs/avatar/#shadow-prop"}>
              Shadow prop in Phoenix Liveview component
            </.link>
          </.heading2>

          <.cp>
            The shadow prop in the Mishka Chelekom Avatar component allows you to control the avatar’s shadow size. You can choose from predefined values, such as <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, <.custom_inline_code>extra_large</.custom_inline_code>, and <.custom_inline_code>none</.custom_inline_code>. By using the shadow prop, you can also apply your own custom class or Tailwind CSS class to add custom shadow effects to the avatar.
          </.cp>

          <.custom_code_wrapper elements_class="[&>*]:mb-2 text-sm" code={@code_18}>
            <div class="flex gap-2">
              <.avatar id="avatar59" size="extra_large" shadow="extra_small">
                TG
              </.avatar>
              <.avatar
                id="avatar60"
                size="extra_large"
                shadow="small"
                color="warning"
                alt="Mishka Chelekom avatar component"
                src={~p"/images/avatar5.jpg"}
              />
              <.avatar id="avatar" size="extra_large" shadow="medium" color="secondary">
                JJ
              </.avatar>
              <.avatar id="avatar61" size="extra_large" shadow="large" color="success">
                <:icon name="hero-photo" />
              </.avatar>
              <.avatar id="avatar62" size="extra_large" shadow="extra_large" color="warning">
                <:icon name="hero-heart" />
              </.avatar>
              <.avatar id="avatar63" size="extra_large" shadow="none" color="danger">
                <:icon name="hero-heart" />
              </.avatar>
            </div>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="display-indicator">
            <.link patch={~p"/chelekom/docs/avatar/#display-indicator"}>
              Display indicator on avatars
            </.link>
          </.heading2>

          <.cp>
            You can easily using
            <.link
              title="Mishka Chelekom indicator component"
              class="transition-colors hover:text-[#448D96]"
              navigate={~p"/chelekom/docs/indicator"}
            >
              indicator component
            </.link>
            to the Mishka Chelekom Avatar component to visually represent status or notifications. By including the
            <.custom_inline_code>indicator</.custom_inline_code>
            tag within the avatar, you can customize the size, color, and position of the indicator. For example, using the top_left attribute places the indicator in the top-left corner of the avatar. This feature allows for a more dynamic user experience, such as showing online statuses, notifications, or alerts alongside profile images or icons. By using the pinging prop on the <.custom_inline_code>indicator</.custom_inline_code>, you can add a pinging animation to the avatar, making it more dynamic and visually engaging.
          </.cp>

          <.custom_code_wrapper elements_class="[&>*]:mb-2 text-sm" code={@code_19}>
            <div class="flex gap-2 px-2">
              <.avatar id="avatar64" size="large" color="primary" border="small">
                <:icon name="hero-users" />
                <.indicator size="small" color="danger" top_left />
              </.avatar>

              <.avatar id="avatar65" size="large" color="silver" border="small">
                TG <.indicator size="small" color="misc" bottom_left />
              </.avatar>

              <.avatar
                id="avatar66"
                size="extra_large"
                alt="Mishka Chelekom avatar component"
                src={~p"/images/avatar5.jpg"}
              >
                <:icon name="hero-heart" />
                <.indicator size="small" color="success" top_right pinging />
              </.avatar>
            </div>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="avatar-group">
            <.link patch={~p"/chelekom/docs/avatar/#avatar-group"}>
              Avatar group
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>avatar_group</.custom_inline_code>
            component in the Mishka Chelekom library allows you to display multiple avatars together in a compact, visually cohesive layout. This feature is ideal for representing teams, group members, or social interactions. Additionally, you can add a placeholder, like +20, using the
            <.custom_inline_code>avatar</.custom_inline_code>
            tag to represent additional members in the group when space is limited.
          </.cp>

          <.custom_code_wrapper elements_class="[&>*]:mb-2 text-sm" code={@code_20}>
            <.avatar_group id="avatargroup1">
              <.avatar
                id="avatar67"
                src={~p"/images/avatar1.png"}
