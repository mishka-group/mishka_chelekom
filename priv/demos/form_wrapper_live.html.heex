<Layouts.app flash={@flash}>
  <div class="lg:grid lg:grid-cols-12 mt-5 max-w-5xl mx-auto">
    <.custom_nav active="chelekom-docs-forms" />
    <div class="lg:col-span-10">
      <.custom_info
        title="Form Wrapper"
        description="Form components for Phoenix and Phoenix LiveView, featuring floating labels and various input styles."
        mix="mix mishka.ui.gen.component form_wrapper"
        github="https://github.com/mishka-group/mishka_chelekom/blob/master/priv/components/form_wrapper.eex"
        tags={["Component", "Stateless", "JS-module"]}
      />
      <.custom_tab id="chelekom-forms-tab">
        <:documentation_panel>
          <.heading2 class="mb-5" id="overview">
            <.link patch={~p"/chelekom/docs/forms/#overview"}>
              Overview of the Phoenix and LiveView Form Component
            </.link>
          </.heading2>
          <.cp>
            The
            <strong>
              Mishka Chelekom form
            </strong>
            component is a <strong>Phoenix LiveView</strong>
            component that allows developers to create consistent and customizable
            <strong>forms</strong>
            using various input types, including text, number, email, telephone, and textarea fields. Each of these input types shares the same design and style, ensuring a unified and polished look across the form.
          </.cp>

          <.custom_code_wrapper elements_class="grid lg:grid-cols-2 gap-5">
            <div class="space-y-4">
              <.text_field
                name="sample-1"
                space="small"
                size="small"
                floating="outer"
                value=""
                label="Text field"
                placeholder="Text Input"
                class="[&_.text-field-wrapper]:!shadow-xs"
              />
              <.email_field
                name="sample-2"
                space="small"
                size="small"
                description="Please insert a work email"
                value=""
                label="Email field"
                placeholder="Email Input"
                class="[&_.rmail-field-wrapper]:!shadow-xs"
              />
              <.number_field
                name="sample-3"
                space="small"
                size="small"
                value=""
                label="Number field"
                placeholder="Number Input"
                error_icon="hero-shield-exclamation"
                errors={["An error occured"]}
                class="[&_.number-field-wrapper]:!shadow-xs"
              />
              <.date_time_field
                name="sample-4"
                space="small"
                size="small"
                value=""
                label="date time field"
                placeholder="date time Input"
                class="[&_.date-time-field-wrapper]:!shadow-xs"
              />
              <.password_field
                name="sample-5"
                space="small"
                size="small"
                show_password
                value=""
                label="Password field"
                placeholder="Password Input"
                class="[&_.password-field-wrapper]:!shadow-xs"
              />
              <.search_field
                name="sample-7"
                space="small"
                size="small"
                value="Mishka chelekom"
                label="Search field"
                placeholder="Search Input"
                class="[&_.search-field-wrapper]:!shadow-xs"
              />
              <.native_select
                name="sample-8"
                label="Native select"
                variant="base"
                size="small"
                color="base"
                id="sample-8"
                space="small"
                class="[&_.select-field]:!shadow-xs"
              >
                <:option value="" selected>
                  Choose one
                </:option>

                <:option value="v1">
                  Backend developer
                </:option>

                <:option value="v2">
                  Frontend developer
                </:option>

                <:option value="v3">
                  Full stack developer
                </:option>
              </.native_select>
              <.tel_field
                name="sample-5"
                space="small"
                size="small"
                value=""
                label="Tel field"
                placeholder="Tel Input"
                class="[&_.tel-field-wrapper]:!shadow-xs"
              >
                <:start_section>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-4"
                  >
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                </:start_section>
              </.tel_field>
              <.url_field
                name="sample-6"
                space="small"
                size="small"
                value=""
                label="Url field"
                placeholder="Url Input"
                class="[&_.url-field-wrapper]:!shadow-xs"
              >
                <:end_section>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-4"
                  >
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                  </svg>
                </:end_section>
              </.url_field>
              <.textarea_field
                name="sample-9"
                description="Every field can have description"
                space="extra_small"
                floating="inner"
                size="small"
                value=""
                label="Textarea field"
                class="[&_textarea]:min-h-20 [&_.textarea-field-wrapper]:!shadow-xs"
                rows="4"
              />
            </div>
            <div class="space-y-6 bg-white shadow-lg border border-[#E5E7EB] dark:bg-[#323238] py-5 px-3 rounded-lg dark:border-[#454549] h-fit">
              <.text_field
                name="sample-10"
                space="small"
                size="medium"
                rounded="large"
                value=""
                label="Name *"
                placeholder="Enter your name"
                class="[&_.text-field-wrapper]:!shadow-xs"
              />
              <.email_field
                name="sample-11"
                space="small"
                size="medium"
                rounded="large"
                value=""
                label="Email *"
                placeholder="Enter your Email"
                class="[&_.email-field-wrapper]:!shadow-xs"
              />
              <.password_field
                name="sample-12"
                space="small"
                size="medium"
                rounded="large"
                value=""
                label="Password *"
                placeholder="Enter your password"
                class="[&_.password-field-wrapper]:!shadow-xs"
              />
              <.native_select
                name="sample-20"
                space="small"
                size="small"
                rounded="large"
                id="sample-20"
                label="Country"
                class="[&_.select-field]:!shadow-xs"
              >
                <:option value="" selected>
                  Choose a country
                </:option>

                <:option value="nl">
                  NL
                </:option>

                <:option value="usa">
                  USA
                </:option>

                <:option value="uae">
                  UAE
                </:option>
              </.native_select>
              <.checkbox_field
                name="sample-14"
                value=""
                space="small"
                size="large"
                label="I agree to the terms and conditions"
                color="misc"
                class="[&_label]:text-black dark:[&_label]:text-white"
              />
              <div class="flex items-center justify-between gap-5">
                <.button
                  size="leading-5 py-2 px-4"
                  class="flex-1"
                  variant="bg-violet-700 border-violet-600 hover:bg-violet-600 text-white dark:bg-violet-400 dark:hover:bg-violet-500 dark:border-violet-500"
                >
                  Submit
                </.button>
                <.button size="leading-5 py-2 px-5">Reset</.button>
              </div>
            </div>
          </.custom_code_wrapper>

          <.cp margin="mt-5">
            This
            <strong>
              <.link
                title="Phoenix LiveView form component"
                class="transition-colors hover:text-[#448D96]"
                navigate={~p"/chelekom"}
              >
                Phoenix LiveView form component
              </.link>
            </strong>
            supports uniform styling for all form elements, including input fields, floating labels, and validation messages, providing a seamless user experience. Its responsive and flexible design makes it easy to apply across different input types while maintaining a consistent and professional appearance.
          </.cp>

          <.custom_block position="left" color="success" class="my-8" border="medium">
            <.cp>
              By using the class prop, you can apply custom classes or
              <strong>Tailwind CSS</strong>
              classes to customize the appearance and behavior of the gallery, allowing for flexible design changes.
            </.cp>
          </.custom_block>

          <.heading2 margin="my-5" id="base-forms">
            <.link patch={~p"/chelekom/docs/forms/#base-forms"}>
              Base Variant
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="space-y-4" code={@code_1}>
            <.text_field
              id="form-example-88777"
              name="form-example-88777"
              space="small"
              value=""
              label="Text field"
              placeholder="Mishka chelekom input"
            />
            <.email_field
              id="form-example-3232"
              name="form-example-3232"
              space="small"
              value=""
              label="Email field"
              placeholder="Mishka chelekom input"
            />
