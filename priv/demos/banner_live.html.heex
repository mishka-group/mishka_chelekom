                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-11"
              >
                Show Secondary
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-1"}
              id="banner_natural_doc_1"
              dismiss_size="extra_large"
              variant="default"
            >
              Banner Default variant natural
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-110"}
              id="banner_natural_doc_110"
              dismiss_size="extra_large"
              variant="default"
              color="white"
            >
              Banner Default variant White
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-111"}
              id="banner_natural_doc_111"
              dismiss_size="extra_large"
              variant="default"
              color="dark"
            >
              Banner Default variant Dark
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-3"}
              id="banner_info_doc_3"
              color="info"
              variant="default"
            >
              Banner Default variant Info
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-4"}
