              >
                Show Extra Large Space
              </.button>
              <.button
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-75"
                variant="outline"
                color="danger"
              >
                Show No Space
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-70"}
              id="banner_space_doc_71"
              space="extra_small"
              color="dawn"
              variant="default"
            >
              Space extra small 70
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-71"}
              id="banner_space_doc_72"
              space="small"
              color="misc"
              variant="default"
            >
              Space small 71
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-72"}
              id="banner_space_doc_73"
              space="medium"
              color="info"
              variant="default"
            >
              Space medium 72
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-73"}
              id="banner_space_doc_74"
              space="large"
              color="primary"
              variant="default"
            >
              Space large 73
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-74"}
              id="banner_space_doc_75"
              space="extra_large"
              color="secondary"
              variant="default"
            >
              Space extra large 74
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-75"}
              id="banner_space_doc_76"
              space="none"
              variant="default"
            >
              Space none 75
            </.banner>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="banner-padding">
            <.link patch={~p"/chelekom/docs/banner/#banner-padding"}>
              Padding prop
            </.link>
          </.heading2>

          <.cp>
            The padding in the Phoenix LiveView banner component provides various padding size options, including <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. These options define the amount of space between the content inside the banner and its edges, with increasing amounts of padding from
            <.custom_inline_code>extra_small</.custom_inline_code>
            to <.custom_inline_code>extra_large</.custom_inline_code>. If no specific value is provided, the default padding is set to <.custom_inline_code>extra_small</.custom_inline_code>, ensuring a balanced and consistent look for the component.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_10}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="dawn"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-75"
              >
                Show Extra Small Padding
              </.button>
              <.button
                color="misc"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-76"
              >
                Show Small Padding
              </.button>
              <.button
                color="silver"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-77"
              >
                Show Medium Padding
              </.button>
              <.button
                color="info"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-78"
              >
                Show Large Padding
              </.button>
              <.button
                color="primary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-79"
              >
                Show Extra Large Padding
              </.button>
              <.button
                color="secondary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-80"
              >
                Show No Padding
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-75"}
              id="banner_padding_doc_76"
              padding="extra_small"
              color="dawn"
              variant="default"
            >
              Padding extra small 75
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-76"}
              id="banner_padding_doc_77"
              padding="small"
              color="misc"
              variant="default"
            >
              Padding small 76
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-77"}
              id="banner_padding_doc_78"
              padding="medium"
              color="silver"
              variant="default"
            >
              Padding medium 77
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-78"}
              id="banner_padding_doc_79"
              padding="large"
              color="info"
              variant="default"
            >
              Padding large 78
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-79"}
              id="banner_padding_doc_80"
              padding="extra_large"
              color="primary"
              variant="default"
            >
              Padding extra large 79
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-80"}
              id="banner_padding_doc_81"
              padding="none"
              color="secondary"
              variant="default"
            >
              Padding none 80
            </.banner>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="banner-font-weight">
            <.link patch={~p"/chelekom/docs/banner/#banner-font-weight"}>
              Font weight prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>font_weight</.custom_inline_code>
            prop in the Phoenix LiveView banner component allows you to customize the font weight of the text within the banner using Tailwind CSS classes. By default, it is set to <.custom_inline_code>font-normal</.custom_inline_code>, giving the text a regular weight. However, you can easily modify this by passing a different Tailwind class for font weight, such as
            <.custom_inline_code>font-bold</.custom_inline_code>
            to make the text bold, or other classes like
            <.custom_inline_code>font-silver</.custom_inline_code>
            or
            <.custom_inline_code>font-medium</.custom_inline_code>
            to adjust the thickness of the text as per your design needs. This flexibility allows for easy control over the typography within the banner, ensuring it aligns with the desired visual hierarchy.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_11}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="primary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-81"
              >
                Show Font silver
              </.button>
              <.button
                color="secondary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-82"
              >
                Show Font Thin
              </.button>
              <.button
                color="warning"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-83"
              >
                Show Font Black
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-81"}
              id="banner_font_doc_82"
              font_weight="font-silver"
              color="primary"
              variant="default"
            >
              Font silver 81
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-82"}
              id="banner_font_doc_83"
              font_weight="font-thin"
              color="secondary"
              variant="default"
            >
              Font thin 82
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-83"}
              id="banner_font_doc_84"
              font_weight="font-black"
              color="warning"
              variant="default"
            >
              Font black 83
            </.banner>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="banner-vertical">
            <.link patch={~p"/chelekom/docs/banner/#banner-vertical"}>
              Vertical position and vertical size props in Phoenix LiveView banner component
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>vertical_position</.custom_inline_code>
            and
            <.custom_inline_code>vertical_size</.custom_inline_code>
            props in the Phoenix LiveView banner component give you control over where the banner appears vertically on the screen and how much space is between the banner and the screen's edge. The
            <.custom_inline_code>vertical_position</.custom_inline_code>
            prop can be set to either
            <.custom_inline_code>top</.custom_inline_code>
            or <.custom_inline_code>bottom</.custom_inline_code>, determining whether the banner is aligned at the top or bottom of the viewport. Meanwhile, the
            <.custom_inline_code>vertical_size</.custom_inline_code>
            prop adjusts the spacing, with options like <.custom_inline_code>none</.custom_inline_code>, <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. These size values control how much space is applied between the banner and the top or bottom edge, allowing you to tailor the layout according to your design needs, whether you want the banner to be flush against the edge or spaced further away.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_12}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="secondary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-84"
              >
                Show Banner (Bottom, Extra Large)
              </.button>
              <.button
                color="misc"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-85"
              >
                Show Banner (Bottom, Small)
              </.button>
              <.button
                color="danger"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-86"
              >
                Show Banner (Extra Large)
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-84"}
              id="banner_vertical_doc_85"
              vertical_position="bottom"
              vertical_size="extra_large"
              color="secondary"
              variant="default"
            >
              Banner Bottom extra large space
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-85"}
              id="banner_vertical_doc_86"
              vertical_position="bottom"
              vertical_size="small"
              color="misc"
              variant="default"
            >
              Banner Bottom with small space
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-86"}
              id="banner_vertical_doc_87"
              vertical_size="extra_large"
              color="danger"
              variant="default"
            >
              Banner top with small space
            </.banner>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="banner-positions">
            <.link patch={~p"/chelekom/docs/banner/#banner-positions"}>
              Position and position size props
            </.link>
          </.heading2>

          <.cp>
            The position and
            <.custom_inline_code>position_size</.custom_inline_code>
            props in the Phoenix LiveView banner component allow for flexible control over the horizontal and vertical placement of the banner. The position prop offers various alignment options, such as <.custom_inline_code>top_left</.custom_inline_code>, <.custom_inline_code>top_right</.custom_inline_code>, <.custom_inline_code>bottom_left</.custom_inline_code>, <.custom_inline_code>bottom_right</.custom_inline_code>, <.custom_inline_code>center</.custom_inline_code>, and <.custom_inline_code>full</.custom_inline_code>. These determine where the banner will be placed on the screen. The position_size prop adds even more flexibility by controlling the distance between the banner and the edges of the viewport. You can choose values like <.custom_inline_code>none</.custom_inline_code>, <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>, adjusting how far the banner is from the specified position, whether it's on the top-left, top-right, bottom-left, or bottom-right. This allows for precise control over banner placement, ensuring it fits the layout and design requirements of the application.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_13}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="success"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-115"
              >
                Show Banner top left
              </.button>
              <.button
                color="warning"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-116"
              >
                Show Banner top right
              </.button>
              <.button
                color="danger"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-117"
              >
                Show Banner full
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-115"}
              id="banner_vertical_doc_115"
              position="top_left"
              color="success"
              variant="default"
            >
              Banner Position top left
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-116"}
              id="banner_vertical_doc_116"
              position="top_right"
              color="warning"
              variant="default"
            >
              Banner Position top right
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-117"}
              id="banner_vertical_doc_117"
              color="danger"
              variant="default"
            >
              Banner position full
            </.banner>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="banner-dismiss-position">
            <.link patch={~p"/chelekom/docs/banner/#banner-dismiss-position"}>
              Dismiss button position
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>right_dismiss</.custom_inline_code>
            and
            <.custom_inline_code>left_dismiss</.custom_inline_code>
            props are boolean attributes in the Phoenix LiveView banner component that control the placement of the dismiss button. When right_dismiss is set to true, the dismiss button appears on the right side of the banner, allowing users to close the banner from that side. Similarly, setting left_dismiss to true places the dismiss button on the left side of the banner. By default, if neither prop is specified, the dismiss button will be positioned on the left side, as the
            <.custom_inline_code>left_dismiss</.custom_inline_code>
            behavior is considered the default. These options provide flexibility for aligning the dismiss button based on the design and user interaction needs.
          </.cp>

          <.custom_block color="warning" position="left" class="my-8" border="medium">
            All components that have a dismiss button. When performing the operation,
            it sends an event to the server. for example
            <.custom_inline_code>handle_event("dismiss", params, socket)</.custom_inline_code>
          </.custom_block>

          <.custom_code_wrapper code_class="text-sm" code={@code_14}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="danger"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-87"
              >
                Show Right Dismiss
              </.button>
              <.button
                color="info"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-88"
              >
                Show Left Dismiss
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-87"}
              id="banner_vertical_doc_87"
              right_dismiss
              color="danger"
              variant="default"
            >
              Banner Right dismiss
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-88"}
              id="banner_vertical_doc_88"
              left_dismiss
              color="info"
              variant="default"
            >
              Banner Left dismiss
            </.banner>
          </.custom_code_wrapper>
        </:documentation_panel>

        <:props_panel>
          <.custom_search class="mb-16" />
          <div class="space-y-8">
            <h2 class="text-lg lg:text-2xl font-bold">Banner component props</h2>

            <.custom_table id="banner-component-table">
              <:header>
                <.table_th>Name</.table_th>

                <.table_th>Type</.table_th>

                <.table_th>Required</.table_th>

                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>

                <.table_td>string</.table_td>

                <.table_td>Yes</.table_td>

                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the overall size of the elements, including padding, font size, and other items. Default: <strong>large</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>dismiss_size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Add custom classes to control dismiss sizes
                </.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the style of the banner. Supported values: <strong>base</strong>, <strong>default</strong>, <strong>outline</strong>, <strong>transparent</strong>, <strong>shadow</strong>, <strong>bordered</strong>, <strong>gradient</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the color theme of the banner. Supported values: <strong>natural</strong>, <strong>primary</strong>, <strong>secondary</strong>, <strong>success</strong>, <strong>warning</strong>, <strong>danger</strong>, <strong>info</strong>, <strong>silver</strong>, <strong>misc</strong>, <strong>dawn</strong>. The
                  <strong>default</strong>
                  and <strong>bordered</strong>
                  variants have extra color options: <strong>dark</strong>
                  and <strong>white</strong>, which in both light mode and dark mode, these colors are always the same.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border style. Default: <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border_position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border position. Supported values: <strong>top</strong>, <strong>bottom</strong>, <strong>full</strong>, <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>rounded</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the border radius. Supported values: <strong>extra_small</strong>, <strong>small</strong>, <strong>medium</strong>, <strong>large</strong>, <strong>extra_large</strong>, <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>rounded_position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the rounded position. Supported values: <strong>top</strong>, <strong>bottom</strong>, <strong>all</strong>, <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>space</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Space between items. Supported values: <strong>extra_small</strong>, <strong>small</strong>, <strong>medium</strong>, <strong>large</strong>, <strong>extra_large</strong>, <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical_position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Specifies the vertical position of the banner. Supported values: <strong>top</strong>, <strong>bottom</strong>. Default: <strong>top</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical_size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Specifies the vertical size of the element. Default: <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>position</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the element position. Supported values: <strong>top_left</strong>, <strong>top_right</strong>, <strong>bottom_left</strong>, <strong>bottom_right</strong>, <strong>center</strong>, <strong>full</strong>. Default: <strong>full</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>position_size</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines the size for positioning the element. Supported values: <strong>extra_small</strong>, <strong>small</strong>, <strong>medium</strong>, <strong>large</strong>, <strong>extra_large</strong>, <strong>none</strong>. Default: <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>font_weight</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines custom class for the font weight. Default: <strong>font-normal</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>padding</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Determines padding for items. Supported values: <strong>extra_small</strong>, <strong>small</strong>, <strong>medium</strong>, <strong>large</strong>, <strong>extra_large</strong>, <strong>none</strong>. Default: <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>

                <.table_td>string</.table_td>

                <.table_td>No</.table_td>

                <.table_td>Custom CSS class for additional styling.</.table_td>
              </:row>

              <:row>
                <.table_td>right_dismiss</.table_td>

                <.table_td>boolean</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Adds a dismiss button positioned on the right side of the banner.
                </.table_td>
              </:row>

              <:row>
                <.table_td>left_dismiss</.table_td>

                <.table_td>boolean</.table_td>

                <.table_td>No</.table_td>

                <.table_td>
                  Adds a dismiss button positioned on the left side of the banner.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/banner/#overview"}
