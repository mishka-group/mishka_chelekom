              id="banner_silver_doc_7"
              variant="default"
              color="silver"
            >
              Banner Default variant silver
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-8"}
              id="banner_misc_doc_8"
              variant="default"
              color="misc"
            >
              Banner Default variant Misc
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-9"}
              id="banner_dawn_doc_9"
              variant="default"
              color="dawn"
            >
              Banner Default variant Dawn
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-10"}
              id="banner_primary_doc_10"
              color="primary"
              variant="default"
            >
              Banner Default variant Primary
            </.banner>
            <.banner
