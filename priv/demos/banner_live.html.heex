          <:content link={~p"/chelekom/docs/banner/#banner-space"} title="Space prop" />
          <:content link={~p"/chelekom/docs/banner/#banner-padding"} title="Padding prop" />
          <:content link={~p"/chelekom/docs/banner/#banner-font-weight"} title="Font weight prop" />
          <:content
            link={~p"/chelekom/docs/banner/#banner-vertical"}
            title="Vertical position and vertical size props"
          />
          <:content
