              id="banner_secondary_doc_11"
              color="secondary"
              variant="default"
            >
              Banner Default variant Secondary
            </.banner>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="outline-variant-banner">
            <.link patch={~p"/chelekom/docs/banner/#outline-variant-banner"}>
              Outline Variant
            </.link>
          </.heading2>

          <.cp>
            The outline style of the Mishka Chelekom banner features a border. Using a single setting, you can choose from various color variants to suit your design needs.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_2}>
