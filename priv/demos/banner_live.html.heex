              color="success"
              variant="default"
            >
              Banner Default variant Success
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-5"}
              id="banner_warning_doc_5"
              color="warning"
              variant="default"
            >
              Banner Default variant Warning
            </.banner>
            <.banner
