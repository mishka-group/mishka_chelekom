          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="border-position-banner">
            <.link patch={~p"/chelekom/docs/banner/#border-position-banner"}>
              Border position in Phoenix LiveView banner component
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>border_position</.custom_inline_code>
            attribute in the Mishka Chelekom Banner component controls the placement of the border on the banner. It accepts values such as <.custom_inline_code>top</.custom_inline_code>, <.custom_inline_code>bottom</.custom_inline_code>, <.custom_inline_code>full</.custom_inline_code>, and <.custom_inline_code>none</.custom_inline_code>. By default, the border is positioned at the bottom of the banner. Setting the value to
            <.custom_inline_code>top</.custom_inline_code>
            adds a border at the top, while
            <.custom_inline_code>full</.custom_inline_code>
            applies a border around the entire banner. The
            <.custom_inline_code>none</.custom_inline_code>
            option removes the border entirely, offering full flexibility in banner styling.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_7}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="silver"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-61"
              >
                Show Bottom Border
              </.button>
              <.button
                color="primary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-62"
              >
                Show Top Border
              </.button>
              <.button
                color="secondary"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-63"
              >
                Show Full Border
              </.button>
              <.button
                color="dawn"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-64"
              >
                Show No Border
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-61"}
              id="banner_border_doc_62"
              color="silver"
              variant="default"
              border_position="bottom"
            >
              Border small of Banner 61
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-62"}
              id="banner_border_doc_63"
              color="primary"
              variant="default"
              border_position="top"
            >
              Border extra small of Banner 62
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-63"}
              id="banner_border_doc_64"
              color="secondary"
              variant="default"
              border_position="full"
            >
              Border medium of Banner 63
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-64"}
              id="banner_border_doc_65"
