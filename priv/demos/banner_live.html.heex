              Border large of Banner 64
            </.banner>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="banner-rounded">
            <.link patch={~p"/chelekom/docs/banner/#banner-rounded"}>
              Rounded and Rounded Position props
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>rounded</.custom_inline_code>
            and
            <.custom_inline_code>rounded_position</.custom_inline_code>
            props in the Phoenix LiveView banner component provide flexibility for customizing the border radius of the banner's corners. By default, no border radius is applied (i.e.,
            <.custom_inline_code>rounded="none</.custom_inline_code>
            and <.custom_inline_code>rounded_position="none</.custom_inline_code>), meaning the banner’s corners will remain sharp. However, if you wish to apply a rounded effect, you can specify a value for the
            <.custom_inline_code>rounded</.custom_inline_code>
            prop, which controls the size of the rounding (e.g., <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, <.custom_inline_code>extra_large</.custom_inline_code>). Once you’ve set the rounding size, you can further refine the look by choosing a value for the
            <.custom_inline_code>rounded_position</.custom_inline_code>
            prop to determine which corners are rounded. For instance, setting
            <.custom_inline_code>rounded_position="top</.custom_inline_code>
            will only round the top corners,
            <.custom_inline_code>rounded_position="bottom</.custom_inline_code>
            will round just the bottom corners, and
            <.custom_inline_code>rounded_position="all</.custom_inline_code>
            will round all four corners of the banner. This combination allows for customizable and visually appealing banners that fit the design needs of your Phoenix LiveView application.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_8}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="misc"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-65"
              >
                Show Extra Small Rounded (Bottom)
              </.button>
              <.button
                color="dawn"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-66"
              >
                Show Small Rounded (Top)
              </.button>
              <.button
                color="info"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-67"
              >
                Show Medium Rounded (All)
              </.button>
              <.button
                color="success"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-68"
              >
                Show Large Rounded (Top)
              </.button>
              <.button
                color="danger"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-69"
              >
                Show Extra Large Rounded (Bottom)
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-65"}
              id="banner_rounded_doc_66"
              rounded="extra_small"
              rounded_position="bottom"
              color="misc"
              variant="default"
            >
              Rounded extra small 65
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-66"}
              id="banner_rounded_doc_67"
              rounded="small"
              rounded_position="top"
              color="dawn"
              variant="default"
            >
              Rounded small 66
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-67"}
              id="banner_rounded_doc_68"
              rounded="medium"
              rounded_position="all"
              color="info"
              variant="default"
            >
              Rounded medium 67
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-68"}
              id="banner_rounded_doc_69"
              rounded="large"
              rounded_position="top"
              color="success"
              variant="default"
            >
              Rounded large 68
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-69"}
              id="banner_rounded_doc_70"
              rounded="extra_large"
              rounded_position="bottom"
              color="danger"
              variant="default"
            >
              Rounded extra large 69
            </.banner>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="banner-space">
            <.link patch={~p"/chelekom/docs/banner/#banner-space"}>
              Space prop
            </.link>
          </.heading2>

          <.cp>
            The space prop in the Phoenix LiveView banner component provides various spacing options, including <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>. These options define the vertical spacing between elements, with increasing amounts of space from extra_small to extra_large. If no specific value is provided, the default is set to <.custom_inline_code>extra_small</.custom_inline_code>, but custom values can also be applied when needed.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" code={@code_9}>
            <div class="mb-6 flex items-center gap-2 flex-wrap">
              <.button
                color="dawn"
