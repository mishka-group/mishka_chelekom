              <.button
                color="misc"
                variant="outline"
                size="small"
                phx-click="banner_position"
                phx-value-pos="banner-example-60"
              >
                Show Extra Large Border
              </.button>
            </div>

            <.banner
              :if={@banner_pos == "banner-example-56"}
              id="banner_border_doc_57"
              border="extra_small"
              variant="default"
            >
              Border extra small of Banner 56
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-57"}
              id="banner_border_doc_58"
              color="success"
              border="small"
              variant="default"
            >
              Border small of Banner 57
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-58"}
              id="banner_border_doc_59"
              color="warning"
              border="medium"
              variant="default"
            >
              Border medium of Banner 58
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-59"}
              id="banner_border_doc_60"
              color="danger"
              border="large"
              variant="default"
            >
              Border large of Banner 59
            </.banner>
            <.banner
              :if={@banner_pos == "banner-example-60"}
              id="banner_border_doc_61"
              color="misc"
              border="extra_large"
              variant="default"
            >
              Border extra large of Banner 60
