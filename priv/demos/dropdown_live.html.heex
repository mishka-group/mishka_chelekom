            title="Dropdown clickable prop"
          />

          <:content link={~p"/chelekom/docs/dropdown/#dropdown-nomobile"} title="Nomobile prop" />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-width"}
            title="Dropdown width prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-rounded"}
            title="Dropdown rounded prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-space"}
            title="Dropdown space prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-border"}
            title="Dropdown border prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-padding"}
            title="Dropdown padding prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-content-width"}
            title="Dropdown width prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-content-size"}
            title="Dropdown size prop"
          />

          <:content
            link={~p"/chelekom/docs/dropdown/#dropdown-font-weight-prop"}
            title="Dropdown font weight prop"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
