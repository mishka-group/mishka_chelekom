<Layouts.app flash={@flash}>
  <div class="lg:grid lg:grid-cols-12 mt-5 max-w-5xl mx-auto">
    <.custom_nav active="chelekom-docs-mega-menu" />
    <div class="lg:col-span-10">
      <.custom_info
        title="Mega Menu"
        description="Mega menu component for Phoenix and Phoenix LiveView, serving as a full-width dropdown in the navbar to display an organized list of menu items with customizable sizes, variants, and styles."
        mix="mix mishka.ui.gen.component mega_menu"
        github="https://github.com/mishka-group/mishka_chelekom/blob/master/priv/components/mega_menu.eex"
        tags={["Component", "Stateless", "JS-module"]}
      />
      <.custom_tab id="chelekom-mega-menu-tab">
        <:documentation_panel>
          <.heading2 class="mb-5" id="overview">
            <.link patch={~p"/chelekom/docs/mega-menu/#overview"}>
              Overview of the Phoenix LiveView Mega Menu Component
            </.link>
          </.heading2>

          <.cp>
            The
            <strong>
              Mishka Chelekom mega menu
            </strong>
            component is a highly customizable <strong>Phoenix LiveView</strong>
            tool designed for creating dynamic, multi-level navigation systems.
          </.cp>

          <.custom_code_wrapper>
            <div class="relative w-full flex justify-center gap-5 items-center">
              <.mega_menu
                space="small"
                rounded="large"
                padding="extra_small"
                top_gap="large"
                id="mega-menu-example-3488"
              >
                <:trigger>
                  <.button variant="outline" size="leading-5 py-2 px-4" color="natural">
                    Features
                  </.button>
                </:trigger>

                <div class="lg:flex justify-between ">
                  <div class="p-0 pr-4 lg:flex lg:justify-between lg:w-2/3">
                    <ul class="text-sm text-gray-700  " aria-labelledby="dropdownLargeButton">
                      <h6 class="font-medium text-sm text-gray-500 mb-2">Features</h6>
