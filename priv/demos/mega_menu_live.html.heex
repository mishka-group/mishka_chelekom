              <.mega_menu
                padding="small"
                top_gap="large"
                variant="default"
                color="silver"
                size="extra_small"
                font_weight="font-semibold"
                id="mega-menu-example-28"
              >
                <:trigger>
                  <.button variant="outline" color="silver" size="small">
                    open extra large
