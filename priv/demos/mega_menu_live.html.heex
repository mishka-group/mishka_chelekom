                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Contact
                    </li>
                  </ul>
                  <ul class="hidden mb-4 space-y-4 md:mb-0 sm:block">
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Blog
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Privacy Policy
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Terms of Service
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Documentation
                    </li>
                  </ul>
                  <div class="mt-4 md:mt-0">
                    <h2 class="mb-2 font-semibold">Mishka Chelekom</h2>
                    <.cp class="mb-2">
                      We provide a wide range of components tailored to meet various customer needs and preferences.
                    </.cp>
                  </div>
                </div>
              </.mega_menu>
              <.mega_menu
                space="small"
                rounded="large"
                padding="extra_small"
                top_gap="large"
                color="primary"
                id="mega-menu-example-2"
                variant="default"
