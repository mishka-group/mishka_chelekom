                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Privacy Policy
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Terms of Service
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Documentation
                    </li>
                  </ul>
                </div>
              </.mega_menu>

              <.mega_menu
                border="extra_large"
                padding="small"
                top_gap="large"
                color="danger"
                variant="bordered"
                size="extra_small"
                id="mega-menu-example-15"
              >
                <:trigger>
                  <.button color="danger" variant="outline" size="small">
                    open extra large
                  </.button>
                </:trigger>

                <div class="grid md:grid-cols-2">
                  <ul class="space-y-4 sm:mb-4 md:mb-0">
                    <li class="hover:underline hover:text-blue-600 cursor-pointer">
                      Product Categories
