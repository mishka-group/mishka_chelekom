          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-size"}
            title="Mega Menu Size Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-space"}
            title="Mega Menu Space Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-padding"}
            title="Mega Menu Padding Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-rounded"}
            title="Mega Menu Rounded Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-border"}
            title="Mega Menu Border Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-top-gap"}
            title="Mega Menu top gap Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-font-weight-prop"}
            title="Mega Menu Font Weight Prop"
          />
          <:content
            link={~p"/chelekom/docs/mega-menu/#mega-menu-trigger-slot"}
            title="Trigger Slot"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
