                </:trigger>

                <div class="grid md:grid-cols-2">
                  <ul class="space-y-4 sm:mb-4 md:mb-0">
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Product Categories
                    </li>
                    <li class="hover:underline hover:text-blue-400 cursor-pointer">
                      Customer Support
