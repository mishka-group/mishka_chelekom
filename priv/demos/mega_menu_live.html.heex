                    </li>
                  </ul>
                </div>
              </.mega_menu>
            </div>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="mega-menu-top-gap">
            <.link patch={~p"/chelekom/docs/mega-menu/#mega-menu-top-gap"}>
              Mega menu top gap prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>top_gap</.custom_inline_code>
            attribute can take the following values to set the gap between the trigger and content of the mega menu: <.custom_inline_code>extra_small</.custom_inline_code>, <.custom_inline_code>small</.custom_inline_code>, <.custom_inline_code>medium</.custom_inline_code>, <.custom_inline_code>large</.custom_inline_code>, and <.custom_inline_code>extra_large</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" code={@code_11}>
            <div class="relative w-full flex justify-center gap-5 items-center">
              <.mega_menu
                padding="small"
                top_gap="extra_small"
                color="secondary"
                variant="default"
                size="extra_small"
                font_weight="font-thin"
