                                d="M20.412 9.009v.9-.9Zm3.421-3.421h.9-.9Zm-3.42-3.421v-.9.9Zm-3.422 3.42h-.9.9ZM13 4.208a.9.9 0 1 0 0-1.8v1.8Zm10.593 9.363a.9.9 0 0 0-1.8 0h1.8Zm-16.01-.387a.9.9 0 1 0 0 1.8v-1.8Zm5.417 1.8a.9.9 0 0 0 0-1.8v1.8Zm-5.417 2.534a.9.9 0 1 0 0 1.8v-1.8Zm9.75 1.8a.9.9 0 0 0 0-1.8v1.8Zm3.08-9.408a4.321 4.321 0 0 0 3.055-1.266L22.195 7.37a2.521 2.521 0 0 1-1.783.739v1.8Zm3.055-1.266a4.321 4.321 0 0 0 1.265-3.055h-1.8c0 .668-.265 1.31-.738 1.782l1.273 1.273Zm1.265-3.055a4.321 4.321 0 0 0-1.265-3.056l-1.273 1.273c.473.473.738 1.114.738 1.783h1.8Zm-1.265-3.056a4.321 4.321 0 0 0-3.056-1.266v1.8c.669 0 1.31.266 1.783.739l1.273-1.273Zm-3.056-1.266a4.32 4.32 0 0 0-3.055 1.266l1.273 1.273a2.521 2.521 0 0 1 1.782-.739v-1.8Zm-3.055 1.266a4.32 4.32 0 0 0-1.266 3.056h1.8c0-.67.266-1.31.739-1.783l-1.273-1.273ZM16.09 5.588a4.32 4.32 0 0 0 1.266 3.055L18.63 7.37a2.521 2.521 0 0 1-.739-1.782h-1.8Zm1.266 3.055a4.32 4.32 0 0 0 3.055 1.266v-1.8c-.668 0-1.31-.266-1.782-.739l-1.273 1.273ZM13 2.407H7.583v1.8H13v-1.8ZM1.267 8.724v9.692h1.8V8.724h-1.8Zm6.316 16.01h9.693v-1.8H7.583v1.8Zm16.01-6.318V13.57h-1.8v4.846h1.8Zm-6.317 6.317a6.317 6.317 0 0 0 6.317-6.317h-1.8a4.517 4.517 0 0 1-4.517 4.517v1.8Zm-16.01-6.317a6.317 6.317 0 0 0 6.317 6.317v-1.8a4.517 4.517 0 0 1-4.516-4.517h-1.8Zm6.317-16.01a6.317 6.317 0 0 0-6.317 6.318h1.8a4.517 4.517 0 0 1 4.517-4.517v-1.8Zm0 12.577H13v-1.8H7.583v1.8Zm0 4.334h9.75v-1.8h-9.75v1.8Z"
