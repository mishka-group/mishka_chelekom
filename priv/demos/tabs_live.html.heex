          <.heading2 margin="my-5" id="tabs-tab-slot">
            <.link patch={~p"/chelekom/docs/tabs/#tabs-tab-slot"}>
              Tab slot
            </.link>
          </.heading2>

          <.cp>
            You can easily add tab buttons using the
            <.custom_inline_code>tab</.custom_inline_code>
            slot in the Mishka Chelekom Tabs component, without needing to create new elements.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" elements_class="space-y-5" code={@code_11}>
            <.tabs id="tab-example-56" padding="large" color="warning" variant="default">
              <:tab icon="hero-user-circle">Profile</:tab>
