          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="tabs-tab-slot-active">
            <.link patch={~p"/chelekom/docs/tabs/#tabs-tab-slot-active"}>
              Tab slot active props
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>active</.custom_inline_code>
            prop in the Mishka Chelekom Tabs component determines which tab is currently active. By default, the first tab is set to be active unless otherwise specified. When the
            <.custom_inline_code>active</.custom_inline_code>
            prop is set to true for a specific tab, that tab becomes highsilvered, and its corresponding content is displayed, ensuring users know which tab is currently in focus. This prop helps manage the visibility and navigation between different tab contents effectively.
          </.cp>

          <.custom_code_wrapper code_class="text-sm" elements_class="space-y-5" code={@code_13}>
            <.tabs id="tab-example-58" padding="large" color="misc" variant="pills">
              <:tab icon="hero-user-circle">Profile</:tab>
              <:tab icon="hero-ticket" active>Tickets</:tab>
              <:tab icon="hero-cog-6-tooth">Settings</:tab>

              <:panel>
                <.cp>
                  The Profile tab allows you to view and edit your personal details. Keep your information up to date to ensure a seamless experience across the platform.
                </.cp>
              </:panel>
              <:panel>
                <.cp>
                  In the Tickets tab, you can manage all your active and past tickets. Whether you need assistance or just want to check your ticket history, this tab has all the relevant details.
                </.cp>
              </:panel>
              <:panel>
                <.cp>
                  The Settings tab gives you access to customizable options for your account. Here, you can adjust notifications, privacy settings, and other preferences to personalize your experience.
                </.cp>
              </:panel>
            </.tabs>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="tabs-panel-slot">
            <.link patch={~p"/chelekom/docs/tabs/#tabs-panel-slot"}>
              Tab panel slot
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>panel</.custom_inline_code>
            slot in the Mishka Chelekom Tabs component is required and serves as the container for the content associated with each tab. This slot displays the content that corresponds to the active tab, ensuring that users see the relevant information when they interact with different tabs.
          </.cp>

          <.custom_block color="warning" position="left" class="my-8" border="medium">
            Use class prop to add your custom classes to each panel slot
          </.custom_block>
          <.custom_code_wrapper code_class="text-sm" elements_class="space-y-5" code={@code_14}>
            <.tabs id="tab-example-59" padding="large" color="success" variant="default">
              <:tab icon="hero-user-circle">Profile</:tab>
              <:tab icon="hero-ticket" active>Tickets</:tab>
              <:tab icon="hero-cog-6-tooth">Settings</:tab>

              <:panel>
                <.cp>
                  The Profile tab allows you to view and edit your personal details. Keep your information up to date to ensure a seamless experience across the platform.
                </.cp>
              </:panel>
              <:panel>
                <.cp>
                  In the Tickets tab, you can manage all your active and past tickets. Whether you need assistance or just want to check your ticket history, this tab has all the relevant details.
                </.cp>
              </:panel>
              <:panel>
                <.cp>
                  The Settings tab gives you access to customizable options for your account. Here, you can adjust notifications, privacy settings, and other preferences to personalize your experience.
                </.cp>
              </:panel>
            </.tabs>
          </.custom_code_wrapper>
        </:documentation_panel>

        <:props_panel>
          <.custom_search class="mb-16" />
          <div class="space-y-8">
            <h2 class="text-lg lg:text-2xl font-bold">Tabs Component Props</h2>

            <.custom_table id="tabs-component-props">
              <:header>
                <.table_th>Name</.table_th>
                <.table_th>Type</.table_th>
                <.table_th>Required</.table_th>
                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>
                <.table_td>string</.table_td>
                <.table_td>Yes</.table_td>
                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the style of the tabs. Values: <strong>default</strong>, <strong>base</strong>, <strong>pills</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the color theme of the tabs. Values: <strong>base</strong>, <strong>natural</strong>, <strong>primary</strong>, <strong>secondary</strong>, <strong>success</strong>, etc.
                </.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the border style. Default is <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>hide_list_border</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  To remove tab list border. Default is <strong>false</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>full_width_tab</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  To make border tabs buttons full width. Default is <strong>false</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>content_padding</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Control panels padding size. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>tab_border_size</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Sets the border style for the tab. Default is <strong>small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>size</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the overall size of the elements. Default is <strong>small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>gap</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines the gap between tabs.</.table_td>
              </:row>

              <:row>
                <.table_td>rounded</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the border radius. Default is <strong>none</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>font_weight</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines custom class for the font weight. Default is <strong>font-normal</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>padding</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines padding for items. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>triggers_position</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines the position of triggers. Default is <strong>extra_small</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>vertical</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Determines whether the tabs are displayed vertically. Default is <strong>false</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>placement</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Specifies the placement of the tabs. Default is <strong>start</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Custom CSS class for additional styling. Default is <strong>nil</strong>.
                </.table_td>
              </:row>

              <:row>
                <.table_td>tab</.table_td>
                <.table_td>slot</.table_td>
                <.table_td>Yes</.table_td>
                <.table_td>
                  <strong>icon</strong>: Icon displayed alongside an item <strong>class</strong>: Custom CSS class for additional styling <strong>padding</strong>: Determines padding for items <strong>icon_class</strong>: Custom class for the icon <strong>icon_position</strong>: Determines icon position <strong>active</strong>: Indicates whether the element is currently active and visible <strong>badge</strong>: Add badge to tab <strong>badge_color</strong>: Badge color <strong>badge_position</strong>: Badge position <strong>badge_size</strong>: Badge size <strong>badge_variant</strong>: Badge color variant
                </.table_td>
              </:row>

              <:row>
                <.table_td>panel</.table_td>
                <.table_td>slot</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  <strong>class</strong>: Custom CSS class for additional styling
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/tabs/#overview"}
            title="Overview of the Phoenix LiveView Tabs Component"
          />
          <:content link={~p"/chelekom/docs/tabs/#base-tabs"} title="Base Variant" />
          <:content link={~p"/chelekom/docs/tabs/#default-variant-tabs"} title="Default Variant" />
          <:content link={~p"/chelekom/docs/tabs/#pills-variant-tabs"} title="Pills Variant" />
          <:content link={~p"/chelekom/docs/tabs/#tabs-size-prop"} title="Size prop" />
          <:content link={~p"/chelekom/docs/tabs/#tabs-border-prop"} title="Border prop" />
          <:content link={~p"/chelekom/docs/tabs/#tabs-rounded"} title="Rounded prop" />
          <:content link={~p"/chelekom/docs/tabs/#tabs-padding"} title="Padding prop" />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-font-weight-prop"}
            title="Font Weight prop"
          />
          <:content link={~p"/chelekom/docs/tabs/#tabs-gap-prop"} title="Tab gap prop" />
          <:content link={~p"/chelekom/docs/tabs/#tabs-vertical-prop"} title="Tab vertical prop" />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-placement-prop"}
            title="Tab placement prop"
          />
          <:content link={~p"/chelekom/docs/tabs/#tabs-tab-slot"} title="Tab slot" />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-scrollable-prop"}
            title="Scrollable prop"
          />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-tab-slot-icons"}
            title="Tab slot icons props"
          />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-tab-slot-badge"}
            title="Tab slot badge props"
          />
          <:content
            link={~p"/chelekom/docs/tabs/#tabs-tab-slot-active"}
            title="Tab slot active props"
          />
          <:content link={~p"/chelekom/docs/tabs/#tabs-panel-slot"} title="Tab panel slot" />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
