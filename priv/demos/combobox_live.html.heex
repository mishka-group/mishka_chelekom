              </.combobox>
            </div>
            <.combobox
              id="pet-select"
              name="pets"
              placeholder="Select pets"
              searchable
              multiple
              label="Choose Your Favorite Pets"
              description="Select multiple pets from different categories"
            >
              <:option group="Dogs" value="labrador">Labrador Retriever</:option>
              <:option group="Dogs" value="german_shepherd">German Shepherd</:option>
              <:option group="Dogs" value="golden_retriever">Golden Retriever</:option>
              <:option group="Dogs" value="bulldog">Bulldog</:option>

              <:option group="Cats" value="persian">Persian Cat</:option>
              <:option group="Cats" value="siamese">Siamese Cat</:option>
              <:option group="Cats" value="maine_coon">Maine Coon</:option>
              <:option group="Cats" value="ragdoll">Ragdoll</:option>

              <:option group="Birds" value="parrot">Parrot</:option>
              <:option group="Birds" value="canary">Canary</:option>
              <:option group="Birds" value="parakeet">Parakeet</:option>
              <:option group="Birds" value="cockatiel">Cockatiel</:option>

              <:option group="Small Pets" value="hamster">Hamster</:option>
              <:option group="Small Pets" value="rabbit">Rabbit</:option>
              <:option group="Small Pets" value="guinea_pig">Guinea Pig</:option>
              <:option group="Small Pets" value="ferret">Ferret</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-base">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-base"}>
              Base variant
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_1}>
            <.combobox id="country-select-10" name="countries" placeholder="Select a country">
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-default">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-default"}>
              Default variant
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_2}>
            <.combobox
              id="country-select-2"
              name="country"
              placeholder="Select a country"
              variant="default"
              color="misc"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="combobox-bordred">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-bordred"}>
              Bordred variant
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_3}>
            <.combobox
              id="country-select-9"
              name="country"
              placeholder="Select a country"
              variant="bordered"
              color="dawn"
              multiple
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-label">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-label"}>
              Label prop
            </.link>
          </.heading2>

          <.cp>
            You can use the label prop to add custom title text above the combobox.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_4}>
            <.combobox
              id="country-select-3"
              name="country"
              placeholder="Select a country"
              label="Origin Country"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-description">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-description"}>
              Description prop
            </.link>
          </.heading2>

          <.cp>
            The description prop allows you to add explanatory text below the label for additional context about the combobox.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_5}>
            <.combobox
              id="country-select-4"
              name="country"
              placeholder="Select a country"
              description="Description of filed"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="combobox-rounded">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-rounded"}>
              Rounded prop
            </.link>
          </.heading2>

          <.cp>
            The rounded prop offers values like <.custom_inline_code>"extra_small"</.custom_inline_code>, <.custom_inline_code>"small"</.custom_inline_code>, <.custom_inline_code>"medium"</.custom_inline_code>, <.custom_inline_code>"large"</.custom_inline_code>, and <.custom_inline_code>"extra_large"</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_6}>
            <.combobox
              id="country-select-5"
              name="country"
              placeholder="Select a country"
              rounded="large"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-border">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-border"}>
              Border prop
            </.link>
          </.heading2>

          <.cp>
            The border prop offers values like <.custom_inline_code>"extra_small"</.custom_inline_code>, <.custom_inline_code>"small"</.custom_inline_code>, <.custom_inline_code>"medium"</.custom_inline_code>, <.custom_inline_code>"large"</.custom_inline_code>, and <.custom_inline_code>"extra_large"</.custom_inline_code>.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_7}>
            <.combobox
              id="country-select-6"
              name="country"
              placeholder="Select a country"
              border="medium"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="combobox-padding">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-padding"}>
              Padding prop
            </.link>
          </.heading2>

          <.cp>
            The padding prop offers values such as <.custom_inline_code>"extra_small"</.custom_inline_code>, <.custom_inline_code>"small"</.custom_inline_code>, <.custom_inline_code>"medium"</.custom_inline_code>, <.custom_inline_code>"large"</.custom_inline_code>, and <.custom_inline_code>"extra_large"</.custom_inline_code>. These values control the padding around the content inside the combobox.
          </.cp>
          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_8}>
            <.combobox
              id="country-select-09"
              name="country"
              placeholder="Select a country"
              padding="medium"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-space">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-space"}>
              Space prop
            </.link>
          </.heading2>

          <.cp>
            The space prop offers values such as <.custom_inline_code>"extra_small"</.custom_inline_code>, <.custom_inline_code>"small"</.custom_inline_code>, <.custom_inline_code>"medium"</.custom_inline_code>, <.custom_inline_code>"large"</.custom_inline_code>, and <.custom_inline_code>"extra_large"</.custom_inline_code>.
          </.cp>
          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_14}>
            <.combobox
              id="country-select-7"
              name="country"
              placeholder="Select a country"
              space="medium"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="combobox-size">
            <.link patch={~p"/chelekom/docs/forms/combobox/#combobox-size"}>
              Size prop
            </.link>
          </.heading2>

          <.cp>
            The size prop offers values such as <.custom_inline_code>"extra_small"</.custom_inline_code>, <.custom_inline_code>"small"</.custom_inline_code>, <.custom_inline_code>"medium"</.custom_inline_code>, <.custom_inline_code>"large"</.custom_inline_code>, and <.custom_inline_code>"extra_large"</.custom_inline_code>. These values control the padding around the content inside the combobox.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_9}>
            <.combobox
              id="country-select-8"
              name="country"
              size="large"
              placeholder="Select a country"
              padding="medium"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>
          <.heading2 margin="my-5" id="searchable-prop">
            <.link patch={~p"/chelekom/docs/forms/combobox/#searchable-prop"}>
              Searchable prop
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_10}>
            <.combobox
              id="country-select-14"
              name="country"
              size="large"
              placeholder="Select a country"
              padding="medium"
              searchable
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="searchplaceholder-prop">
            <.link patch={~p"/chelekom/docs/forms/combobox/#searchplaceholder-prop"}>
              Searchable prop
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_11}>
            <.combobox
              id="country-select-15"
              name="country"
              size="large"
              placeholder="Select a country"
              padding="medium"
              searchable
              search_placeholder="Search a country"
            >
              <:option value="ca">Canada</:option>
              <:option value="us">United States</:option>
              <:option value="mx">Mexico</:option>
              <:option value="sp">Spain</:option>
              <:option value="de">Germany</:option>
              <:option value="jp">Japan</:option>
              <:option value="ch">China</:option>
              <:option value="sw">Sweden</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="group">
            <.link patch={~p"/chelekom/docs/forms/combobox/#group"}>
              Group Combobox
            </.link>
          </.heading2>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_12}>
            <.combobox id="vehicle-select" name="vehicles" placeholder="Select a vehicle">
              <:option group="Cars" value="sedan">Sedan</:option>
              <:option group="Cars" value="suv">SUV</:option>
              <:option group="Cars" value="coupe">Sports Coupe</:option>
              <:option group="Cars" value="hatchback">Hatchback</:option>

              <:option group="Motorcycles" value="cruiser">Cruiser</:option>
              <:option group="Motorcycles" value="sport">Sport Bike</:option>
              <:option group="Motorcycles" value="touring">Touring</:option>
              <:option group="Motorcycles" value="dirt">Dirt Bike</:option>

              <:option group="Commercial" value="truck">Delivery Truck</:option>
              <:option group="Commercial" value="van">Cargo Van</:option>
              <:option group="Commercial" value="bus">Bus</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="multiple">
            <.link patch={~p"/chelekom/docs/forms/combobox/#multiple"}>
              Multi Select
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>multiple</.custom_inline_code>
            prop is a boolean that enables multi-select functionality in the combobox. When enabled, users can select multiple options which will appear as tags in the input field.
          </.cp>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_13}>
            <.combobox id="fruits-select" name="fruits" placeholder="Select a fruits" multiple>
              <:option group="Fruits" value="apple">Apple</:option>
              <:option group="Fruits" value="banana">Banana</:option>
              <:option group="Fruits" value="orange">Orange</:option>
              <:option group="Fruits" value="mango">Mango</:option>

              <:option group="Vegetables" value="carrot">Carrot</:option>
              <:option group="Vegetables" value="potato">Potato</:option>
              <:option group="Vegetables" value="tomato">Tomato</:option>
              <:option group="Vegetables" value="cucumber">Cucumber</:option>

              <:option group="Vegetables" value="rice">Rice</:option>
              <:option group="Vegetables" value="wheat">Wheat</:option>
              <:option group="Vegetables" value="corn">Corn</:option>
            </.combobox>
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="creatable-prop">
            <.link patch={~p"/chelekom/docs/forms/combobox/#creatable-prop"}>
              Creatable prop
            </.link>
          </.heading2>

          <.cp>
            The
            <.custom_inline_code>creatable</.custom_inline_code>
            prop enables users to add new options directly from the search input when no matching result is found.
            This is useful for dynamic forms where predefined options may not cover all user needs, such as
            tag management, category assignment, or custom field entries. When enabled, an
            <strong>"Add '[typed text]'"</strong>
            button appears in the dropdown, allowing inline option creation
            without leaving the form. Use the
            <.custom_inline_code>create_label</.custom_inline_code>
            prop to
            customize the button prefix and the
            <.custom_inline_code>on_create</.custom_inline_code>
            prop to
            specify a server event that is pushed when a new option is created.
          </.cp>

          <.custom_block position="left" color="success" class="my-8" border="medium">
            <strong>Note:</strong>
            When using <.custom_inline_code>on_create</.custom_inline_code>,
            your LiveView must reply instead of using <.custom_inline_code>:noreply</.custom_inline_code>.
            Return
            <.custom_inline_code>
              {"{:reply, %{value: val, label: lbl}, socket}"}
            </.custom_inline_code>
            to accept the option, or
            <.custom_inline_code>{"{:reply, %{error: \"reason\"}, socket}"}</.custom_inline_code>
            to reject it and remove it from the dropdown.
            Try typing <strong>"error"</strong>
            in the example below to see the rejection in action.
          </.custom_block>

          <.custom_code_wrapper code_class="text-xs" elements_class="lg:px-20" code={@code_15}>
            <.combobox
              id="language-select"
              options={@creatable_languages}
              placeholder="Select a language"
              searchable
              creatable
              create_label="Add"
              on_create="add_language"
            />
          </.custom_code_wrapper>

          <.heading2 margin="my-5" id="real-world-example">
            <.link patch={~p"/chelekom/docs/forms/checkbox-card/#real-world-example"}>
              Real world example
            </.link>
          </.heading2>

          <.custom_code_wrapper class="mt-10" elements_class="space-y-5">
            <.flash kind={:info} variant="default" padding="small" flash={@flash} />
            <.form_wrapper
              for={@form}
              id="user-form"
              phx-change="validate"
              phx-submit="save"
              space="medium"
            >
              <.h5>Full Name</.h5>
              <.text_field size="small" field={@form[:fullname]} />

              <.h5>Select your area of expertise</.h5>

              <.combobox field={@form[:job]} id="job-select" placeholder="Jobs" searchable>
                <:option :for={item <- Ecto.Enum.values(User, :job)} group="IT" value={"#{item}"}>
                  {String.capitalize("#{item}")}
                </:option>
              </.combobox>

              <.combobox
                field={@form[:hobbies]}
                id="hobbies-select"
                placeholder="hobbiess"
                searchable
                multiple
              >
                <:option :for={item <- Ecto.Enum.values(User, :hobbies)} value={"#{item}"}>
                  {String.capitalize("#{item}")}
                </:option>
              </.combobox>
              <hr class="border-b border-[#E5E7EB] dark:border-gray-700" />

              <.h5>Do you accept terms and conditions?</.h5>
              <.toggle_field
                field={@form[:accepted_terms]}
                checked={toggle_check(:accepted_terms, @form)}
                color="info"
                phx-debounce="300"
              />

              <:actions>
                <.button variant="outline" color="info" size="small" phx-disable-with="Saving...">
                  Save User
                </.button>
              </:actions>
            </.form_wrapper>
          </.custom_code_wrapper>
        </:documentation_panel>

        <:props_panel>
          <.custom_search class="mb-16" />

          <div class="space-y-8 mt-8">
            <h2 class="text-lg lg:text-2xl font-bold">Combobox Component Props</h2>

            <.custom_table id="combobox-field-props">
              <:header>
                <.table_th>Name</.table_th>
                <.table_th>Type</.table_th>
                <.table_th>Required</.table_th>
                <.table_th>Description</.table_th>
              </:header>

              <:row>
                <.table_td>id</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>A unique identifier used to manage state and interaction.</.table_td>
              </:row>

              <:row>
                <.table_td>class</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Custom CSS class for additional styling.</.table_td>
              </:row>

              <:row>
                <.table_td>placeholder</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Placeholder text for the component.</.table_td>
              </:row>

              <:row>
                <.table_td>color</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines the color theme (default is "natural").</.table_td>
              </:row>

              <:row>
                <.table_td>variant</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines the variant theme (default is "base").</.table_td>
              </:row>

              <:row>
                <.table_td>border</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines border style (default is "extra_small").</.table_td>
              </:row>

              <:row>
                <.table_td>rounded</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines the border radius (default is "medium").</.table_td>
              </:row>

              <:row>
                <.table_td>padding</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines padding size (default is "small").</.table_td>
              </:row>

              <:row>
                <.table_td>height</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Dropdown height (default is "h-40").</.table_td>
              </:row>

              <:row>
                <.table_td>label</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Specifies text for the label.</.table_td>
              </:row>

              <:row>
                <.table_td>description</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Short description for the component.</.table_td>
              </:row>

              <:row>
                <.table_td>size</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Determines overall size (default is "small").</.table_td>
              </:row>

              <:row>
                <.table_td>error_icon</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Icon displayed alongside error messages.</.table_td>
              </:row>

              <:row>
                <.table_td>errors</.table_td>
                <.table_td>list</.table_td>
                <.table_td>No</.table_td>
                <.table_td>List of error messages to display.</.table_td>
              </:row>

              <:row>
                <.table_td>name</.table_td>
                <.table_td>any</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Name of the input.</.table_td>
              </:row>

              <:row>
                <.table_td>value</.table_td>
                <.table_td>any</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Value of the input.</.table_td>
              </:row>

              <:row>
                <.table_td>field</.table_td>
                <.table_td>Phoenix.HTML.FormField</.table_td>
                <.table_td>No</.table_td>
                <.table_td>A form field struct retrieved from the form.</.table_td>
              </:row>

              <:row>
                <.table_td>searchable</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Add input search to dropdown of combobox</.table_td>
              </:row>
              <:row>
                <.table_td>search_placeholder</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>Add custom placholder to dropdown search input</.table_td>
              </:row>

              <:row>
                <.table_td>creatable</.table_td>
                <.table_td>boolean</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Enables creating new options from search input when no match is found.
                </.table_td>
              </:row>

              <:row>
                <.table_td>create_label</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Label prefix for the create option button (default is "Create").
                </.table_td>
              </:row>

              <:row>
                <.table_td>on_create</.table_td>
                <.table_td>string</.table_td>
                <.table_td>No</.table_td>
                <.table_td>
                  Event name pushed to the server when a new option is created.
                </.table_td>
              </:row>
            </.custom_table>
          </div>
        </:props_panel>

        <:cli_panel>
          <.custom_cli_props config={component_config()} />
        </:cli_panel>
        <.custom_table_content>
          <:content
            link={~p"/chelekom/docs/forms/combobox/#overview"}
            title="Overview of combobox component"
          />
          <:content link={~p"/chelekom/docs/forms/combobox/#combobox-base"} title="Base variant" />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#combobox-default"}
            title="Default variant"
          />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#combobox-bordred"}
            title="Bordred variant"
          />
          <:content link={~p"/chelekom/docs/forms/combobox/#combobox-label"} title="Label prop" />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#combobox-description"}
            title="Description prop"
          />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#combobox-rounded"}
            title="Rounded prop"
          />
          <:content link={~p"/chelekom/docs/forms/combobox/#combobox-border"} title="Border prop" />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#combobox-padding"}
            title="Padding prop"
          />
          <:content link={~p"/chelekom/docs/forms/combobox/#combobox-space"} title="Space prop" />
          <:content link={~p"/chelekom/docs/forms/combobox/#combobox-size"} title="Size prop" />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#searchable-prop"}
            title="Searchable prop"
          />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#searchplaceholder-prop"}
            title="Search placeholder prop"
          />
          <:content link={~p"/chelekom/docs/forms/combobox/#group"} title="Group" />
          <:content link={~p"/chelekom/docs/forms/combobox/#multiple"} title="Multi Select" />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#creatable-prop"}
            title="Creatable prop"
          />
          <:content
            link={~p"/chelekom/docs/forms/combobox/#real-world-example"}
            title="Real world example"
          />
        </.custom_table_content>
      </.custom_tab>
    </div>
  </div>
</Layouts.app>
