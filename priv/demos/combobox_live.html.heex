                          />
                        </g>
                      </g>
                      <defs>
                        <clipPath id="aaa"><path fill="#fff" d="M0 0h20v20H0z" /></clipPath>
                      </defs>
                    </svg>
                    <span>Denmark</span>
                  </div>
                </:option>
                <:option value="no">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none">
