                            /><path
                              fill="#000"
                              d="M0 10c0 4.3 2.714 7.965 6.522 9.378V.622A10.003 10.003 0 0 0 0 10Z"
                            />
                          </g>
                        </g>
                      </g>
                      <defs>
                        <clipPath id="aa"><path fill="#fff" d="M0 0h20v20H0z" /></clipPath>
                      </defs>
                    </svg>
                    <span>Belgium</span>
                  </div>
                </:option>
                <:option value="dk">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none">
                      <g clip-path="url(#aaa)">
                        <mask
                          id="fasdf43q"
                          width="20"
                          height="20"
                          x="0"
                          y="0"
                          maskUnits="userSpaceOnUse"
                        >
                          <path fill="#fff" d="M0 0h20v20H0V0Z" />
                        </mask>
                        <g mask="url(#fasdf43q)">
                          <path
                            fill="#F0F0F0"
                            d="M10 20c5.523 0 10-4.477 10-10S15.523 0 10 0 0 4.477 0 10s4.477 10 10 10Z"
                          /><path
