                              d="M8.26 9.782c-.604 0-1.188.092-1.737.263a3.477 3.477 0 0 0 6.325 1.95 5.862 5.862 0 0 0-4.587-2.213Zm5.154.884a3.478 3.478 0 0 0-6.61-2.039 7.174 7.174 0 0 1 6.61 2.04Z"
                            />
                          </g>
                        </g>
                      </g>
                      <defs>
                        <clipPath id="a"><path fill="#fff" d="M0 0h20v20H0z" /></clipPath>
                      </defs>
                    </svg>
                    <span>Brazil</span>
                  </div>
                </:option>
                <:option value="be">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none">
                      <g clip-path="url(#aa)">
                        <mask
