                          <path fill="#fff" d="M0 0h20v20H0V0Z" />
                        </mask>
                        <g mask="url(#b34b)">
                          <mask
                            id="c32432dcsc"
                            width="20"
                            height="20"
                            x="0"
                            y="0"
                            maskUnits="userSpaceOnUse"
                          >
                            <path fill="#fff" d="M0 0h20v20H0V0Z" />
                          </mask>
                          <g mask="url(#c32432dcsc)">
                            <path
                              fill="#FFDA44"
                              d="M13.478.622A9.978 9.978 0 0 0 10 0a9.98 9.98 0 0 0-3.478.622L5.652 10l.87 9.378A9.978 9.978 0 0 0 10 20a9.98 9.98 0 0 0 3.478-.622l.87-9.378-.87-9.378Z"
                            /><path
