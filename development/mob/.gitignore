_build/mob_release/

# Plugin scaffolding materialised by `mix mob.deploy --native`. mob_dev writes
# io/mob/plugin/*.kt itself (they carry "Generated by mob_dev — do not edit"
# headers) and copies each activated plugin's bridge out of its hex package,
# recording what it copied in priv/generated/.mob_plugin_artifacts/. Both are
# rewritten on every native build, so committing them only invites hand-edits
# and lets the copies go stale the moment a plugin dep is bumped.
android/app/src/main/java/io/
priv/generated/

# macOS
.DS_Store
