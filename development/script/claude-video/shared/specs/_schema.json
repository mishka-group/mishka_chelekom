{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chelekom component video spec",
  "description": "One spec = one component = one video. Segments are the parts of that video.",
  "type": "object",
  "required": [
    "component",
    "segments"
  ],
  "additionalProperties": false,
  "properties": {
    "component": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "title": {
      "type": "string",
      "description": "Display name on the intro card"
    },
    "tagline": {
      "type": "string",
      "maxLength": 60
    },
    "signature": {
      "enum": [
        "segments",
        "unfold",
        "lift",
        "trace",
        "plain"
      ],
      "default": "plain"
    },
    "scheme": {
      "enum": [
        "dark",
        "light"
      ],
      "default": "dark",
      "description": "Starting theme; a `theme` beat can flip it mid-video"
    },
    "hero": {
      "type": "boolean",
      "default": false
    },
    "needs_markup": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string"
    },
    "narration": {
      "type": "string",
      "description": "Required when hero is true. Under 45 words."
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "title",
          "route",
          "beats"
        ],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 32,
            "description": "Shown on the segment card"
          },
          "subtitle": {
            "type": "string",
            "maxLength": 64
          },
          "route": {
            "type": "string",
            "description": "Path only; origin comes from config"
          },
          "beats": {
            "type": "array",
            "minItems": 2,
            "maxItems": 8,
            "items": {
              "type": "object",
              "required": [
                "caption",
                "action"
              ],
              "additionalProperties": false,
              "properties": {
                "caption": {
                  "type": "string",
                  "maxLength": 48
                },
                "selector": {
                  "type": "string",
                  "description": "Required for every action except `theme`"
                },
                "action": {
                  "enum": [
                    "hover",
                    "click",
                    "type",
                    "paste",
                    "focus",
                    "key",
                    "settle",
                    "theme"
                  ]
                },
                "value": {
                  "type": "string",
                  "description": "For type / paste / key, and light|dark for theme"
                },
                "charDelay": {
                  "type": "integer",
                  "default": 170
                },
                "hold": {
                  "type": "integer",
                  "default": 900
                },
                "accent": {
                  "type": "boolean",
                  "default": false,
                  "description": "Mint highlight. At most one per video."
                },
                "settle": {
                  "type": "integer",
                  "default": 600,
                  "description": "ms to wait after clicking before the first keystroke; raise if leading characters drop"
                }
              }
            }
          }
        }
      }
    }
  }
}
