# Copied to .env on first run. .env is gitignored — never commit real values,
# and rotate anything that has been pasted into a chat, an issue or a PR.

# ---- free/ track -------------------------------------------------------------
# Nothing here is required. The free track runs with this file empty.

# say | kokoro | piper — all local, no key, no quota, no per-character cost.
# `say` is the macOS built-in: nothing to install, so it is the default here.
# kokoro and piper sound better but must be installed first.
TTS_PROVIDER=say
SAY_VOICE=
SAY_RATE=175
KOKORO_VOICE=af_heart
PIPER_MODEL=

# ---- gladia/ track -----------------------------------------------------------
# Gladia is speech-TO-text. It does not generate the narration — local TTS above
# does that. Gladia reads the generated audio back and returns word-level
# timestamps, so captions land on the spoken words instead of the interaction
# beats. Leave empty and the gladia track refuses to run rather than silently
# falling back.
GLADIA_API_KEY=

# ---- optional ----------------------------------------------------------------
# Only used if you wire a paid TTS provider. Not required by either track.
ELEVEN_KEY=
VOICE_ID=

# Hard cap checked BEFORE the first request, because a runaway loop is the real
# risk with metered providers — failed generations still bill.
CHAR_BUDGET=9000

CHELEKOM_DEV_ORIGIN=http://localhost:4002
